log_info() {
    echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_debug() {
    if [ "$DEBUG" = "true" ]; then
        echo -e "[DEBUG] $1" >&2
    fi
}

# --- Step progress + timing --------------------------------------------------
# The orchestrated workflows (full / process / dual) run several heavy steps in
# sequence. These helpers give each step a "Step N/total" header and report how
# long it took, plus a grand total at the end, so a long CPU-bound run shows
# visible progress instead of going quiet for minutes. Timing is whole-second
# wall-clock (plenty for minutes-long transcription) and never affects control
# flow — the timers only print.
_STEP_TOTAL=0      # total steps in the current workflow (0 = unknown, hides "/N")
_STEP_NUM=0        # index of the step currently running
_STEP_START=0      # epoch seconds when the current step began
_WORKFLOW_START=0  # epoch seconds when steps_init was called

fmt_duration() {
    # Humanize a whole-second count: 45 -> "45s", 192 -> "3m12s", 3660 -> "1h01m".
    local s="${1:-0}"
    if [ "$s" -lt 60 ]; then
        printf '%ds' "$s"
    elif [ "$s" -lt 3600 ]; then
        printf '%dm%02ds' "$((s / 60))" "$((s % 60))"
    else
        printf '%dh%02dm' "$((s / 3600))" "$(((s % 3600) / 60))"
    fi
}

log_time() {
    # A timing/stats line, visually distinct from the [INFO]/[SUCCESS] tags.
    echo -e "${GREEN}      \xe2\x8f\xb1${NC}  $1" >&2
}

steps_init() {
    # steps_init [TOTAL] — begin a timed workflow of TOTAL steps (omit or 0 to
    # hide the "/N"). Resets the step counter and starts the grand-total timer.
    _STEP_TOTAL="${1:-0}"
    _STEP_NUM=0
    _WORKFLOW_START=$(date +%s)
}

step() {
    # step "Label" — advance the counter, print the step header, start its timer.
    _STEP_NUM=$((_STEP_NUM + 1))
    _STEP_START=$(date +%s)
    if [ "$_STEP_TOTAL" -gt 0 ]; then
        log_info "Step ${_STEP_NUM}/${_STEP_TOTAL}: $1"
    else
        log_info "Step ${_STEP_NUM}: $1"
    fi
}

step_done() {
    # step_done — report how long the step that `step` started just took.
    local elapsed=$(( $(date +%s) - _STEP_START ))
    if [ "$_STEP_TOTAL" -gt 0 ]; then
        log_time "step ${_STEP_NUM}/${_STEP_TOTAL} finished in $(fmt_duration "$elapsed")"
    else
        log_time "step ${_STEP_NUM} finished in $(fmt_duration "$elapsed")"
    fi
}

steps_total_done() {
    # steps_total_done — report total wall-clock elapsed since steps_init.
    local elapsed=$(( $(date +%s) - _WORKFLOW_START ))
    log_time "all ${_STEP_NUM} steps finished in $(fmt_duration "$elapsed")"
}

check_dependencies() {
    local missing=()

    if ! command -v ffmpeg &> /dev/null; then
        missing+=("ffmpeg")
    fi

    if ! command -v pactl &> /dev/null; then
        missing+=("pactl (pulseaudio-utils or pipewire-pulse)")
    fi

    if ! command -v python3 &> /dev/null; then
        missing+=("python3")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies: ${missing[*]}"
        exit 1
    fi
}

# Verify the Python worker environment (venv + faster-whisper) needed to
# transcribe/summarize. Kept separate from check_dependencies() because
# record-only commands don't need it. Call this BEFORE recording in the
# record-then-process flows so a missing setup fails immediately with a clear
# message instead of after a full meeting has already been captured.
check_python_env() {
    if [ ! -x "$PYTHON" ]; then
        log_error "Python environment is not set up (missing: $PYTHON)."
        log_error "Run ./setup.sh once to create venv/ and install faster-whisper."
        exit 1
    fi
    if ! "$PYTHON" -c "import faster_whisper" 2>/dev/null; then
        log_error "faster-whisper is not installed in the venv ($PYTHON)."
        log_error "Run ./setup.sh, or: \"$PYTHON\" -m pip install faster-whisper requests"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Acoustic echo cancellation (AEC)
#
# On open speakers (no headset) the mic picks up the remote audio playing aloud,
# so the You track carries an echo of the Remote side. This wraps PipeWire's
# WebRTC echo-cancel module: it makes a virtual cancelled mic + a virtual sink
# (which forwards to the real speakers AND feeds the canceller its reference),
# then points the system defaults at them. ShepitNote's dual capture uses the
# defaults, so once AEC is on, the You track is echo-free with no other changes.
# It also cleans your mic for every other app (Zoom/Meet), not just ShepitNote.
# ---------------------------------------------------------------------------
AEC_STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/shepitnote-aec.state"
AEC_SOURCE_NAME="echocancel_source"
AEC_SINK_NAME="echocancel_sink"

aec_is_loaded() {
    pactl list short modules 2>/dev/null \
        | grep -q "module-echo-cancel.*${AEC_SOURCE_NAME}"
}

# Move existing playback streams onto the echo-cancel sink, so turning AEC on
# mid-call also routes the ongoing call through the canceller (streams do not
# follow a default change on their own). Playback only — we deliberately do NOT
# move capture streams, so other apps' mics (e.g. OBS) are left alone. The
# canceller's own stream, if listed, is skipped by its echo-cancel name.
_aec_move_playback_streams() {
    local id
    while read -r id; do
        [ -n "$id" ] && pactl move-sink-input "$id" "$AEC_SINK_NAME" 2>/dev/null
    done < <(pactl list sink-inputs 2>/dev/null | awk '
        /^Sink Input #/ { if (id != "" && ec == 0) print id; id = substr($3, 2); ec = 0; next }
        { if (tolower($0) ~ /echo-cancel|echocancel/) ec = 1 }
        END { if (id != "" && ec == 0) print id }
    ')
}

aec_on() {
    if ! command -v pactl >/dev/null 2>&1; then
        log_error "pactl not found (need PulseAudio/PipeWire tools)."; return 1
    fi
    if aec_is_loaded || [ -f "$AEC_STATE_FILE" ]; then
        log_warn "Echo cancellation already appears active. Use 'aec status' or 'aec off'."
        return 0
    fi
    local src sink
    src=$(pactl get-default-source 2>/dev/null)
    sink=$(pactl get-default-sink 2>/dev/null)
    case "$src" in *echocancel*)
        log_error "Default source is already an echo-cancel device. Run 'aec off' first."
        return 1 ;;
    esac
    if [ -z "$src" ] || [ -z "$sink" ]; then
        log_error "Could not read default source/sink from pactl."; return 1
    fi
    log_info "Loading WebRTC echo canceller..."
    log_info "  mic (master):     $src"
    log_info "  speaker (master): $sink"
    local modid
    modid=$(pactl load-module module-echo-cancel \
        aec_method=webrtc \
        source_name="$AEC_SOURCE_NAME" \
        sink_name="$AEC_SINK_NAME" \
        source_master="$src" \
        sink_master="$sink" \
        use_master_format=1 2>&1)
    if ! [[ "$modid" =~ ^[0-9]+$ ]]; then
        log_error "Failed to load module-echo-cancel: $modid"
        return 1
    fi
    # Wait (bounded, no sleep) for the virtual source to appear before switching.
    local tries=0
    until pactl list short sources 2>/dev/null | grep -q "$AEC_SOURCE_NAME"; do
        tries=$((tries + 1)); [ "$tries" -ge 50 ] && break
    done
    pactl set-default-source "$AEC_SOURCE_NAME" 2>/dev/null \
        || log_warn "Could not set default source to $AEC_SOURCE_NAME"
    pactl set-default-sink "$AEC_SINK_NAME" 2>/dev/null \
        || log_warn "Could not set default sink to $AEC_SINK_NAME"
    # Pull already-playing audio through the canceller too (mid-call enable).
    _aec_move_playback_streams
    printf 'MODULE_ID=%s\nORIG_SOURCE=%s\nORIG_SINK=%s\n' \
        "$modid" "$src" "$sink" > "$AEC_STATE_FILE"
    log_success "Echo cancellation ON (module $modid). Your mic is now echo-cancelled."
    log_info "Test it: AUDIO_SOURCE_TYPE=dual ./shepitnote meeting"
    log_info "Turn off: ./shepitnote aec off   (also reverts on reboot)"
}

aec_off() {
    if ! command -v pactl >/dev/null 2>&1; then
        log_error "pactl not found (need PulseAudio/PipeWire tools)."; return 1
    fi
    # Decide the closing message from the state BEFORE we tear anything down.
    local was_active=false
    if aec_is_loaded || [ -f "$AEC_STATE_FILE" ] \
       || pactl get-default-source 2>/dev/null | grep -q echocancel; then
        was_active=true
    fi
    local modid="" orig_source="" orig_sink=""
    if [ -f "$AEC_STATE_FILE" ]; then
        # State file holds only MODULE_ID/ORIG_SOURCE/ORIG_SINK assignments.
        # shellcheck disable=SC1090
        . "$AEC_STATE_FILE"
        modid="${MODULE_ID:-}"; orig_source="${ORIG_SOURCE:-}"; orig_sink="${ORIG_SINK:-}"
    fi
    # Restore defaults first so nothing points at a device we're about to remove.
    [ -n "$orig_source" ] && pactl set-default-source "$orig_source" 2>/dev/null
    [ -n "$orig_sink" ]   && pactl set-default-sink   "$orig_sink"   2>/dev/null
    [ -n "$modid" ] && pactl unload-module "$modid" 2>/dev/null
    # Safety net: unload any echo-cancel module we own that is still loaded.
    local id
    for id in $(pactl list short modules 2>/dev/null \
                | awk -v n="$AEC_SOURCE_NAME" '/module-echo-cancel/ && $0 ~ n {print $1}'); do
        pactl unload-module "$id" 2>/dev/null
    done
    # If a default still points at a now-removed echo-cancel device (e.g. it was
    # loaded manually with no saved state), fall back to a real hardware device
    # so audio isn't left routed to nothing.
    local hw
    if pactl get-default-source 2>/dev/null | grep -q echocancel; then
        hw=$(pactl list short sources 2>/dev/null \
             | awk '$2 !~ /echocancel/ && $2 !~ /\.monitor$/ {print $2; exit}')
        [ -n "$hw" ] && pactl set-default-source "$hw" 2>/dev/null
    fi
    if pactl get-default-sink 2>/dev/null | grep -q echocancel; then
        hw=$(pactl list short sinks 2>/dev/null | awk '$2 !~ /echocancel/ {print $2; exit}')
        [ -n "$hw" ] && pactl set-default-sink "$hw" 2>/dev/null
    fi
    rm -f "$AEC_STATE_FILE"
    if [ "$was_active" = true ]; then
        log_success "Echo cancellation OFF (defaults restored)."
    else
        log_info "Echo cancellation was not active (nothing to turn off)."
    fi
}

aec_status() {
    echo "Echo cancellation (AEC) status:"
    if aec_is_loaded; then
        echo "  module:         LOADED (module-echo-cancel, webrtc)"
    else
        echo "  module:         not loaded"
    fi
    echo "  default source: $(pactl get-default-source 2>/dev/null)"
    echo "  default sink:   $(pactl get-default-sink 2>/dev/null)"
    [ -f "$AEC_STATE_FILE" ] && { echo "  saved state:"; sed 's/^/    /' "$AEC_STATE_FILE"; }
    if pactl get-default-source 2>/dev/null | grep -q echocancel; then
        echo "  => ACTIVE: your mic is echo-cancelled."
    else
        echo "  => INACTIVE: mic is NOT echo-cancelled. Enable with: ./shepitnote aec on"
    fi
}

aec_command() {
    case "${1:-}" in
        on)      aec_on ;;
        off)     aec_off ;;
        status|"") aec_status ;;
        -h|--help|help)
            echo "Usage: $0 aec {on|off|status}"
            echo ""
            echo "Real-time acoustic echo cancellation for open-speaker meetings."
            echo "Removes the remote audio bleed from your mic (the You track) using"
            echo "PipeWire's WebRTC canceller, and also cleans your mic for Zoom/Meet."
            echo ""
            echo "  on      load the canceller and route your default mic/speaker through it"
            echo "  off     restore your original defaults and unload the canceller"
            echo "  status  show whether AEC is active"
            echo ""
            echo "AEC reverts on reboot; run 'aec on' again (or add it to autostart)."
            ;;
        *)
            log_error "Unknown 'aec' subcommand: $1"
            echo "Usage: $0 aec {on|off|status}" >&2
            return 1
            ;;
    esac
}

record_meeting() {
    local duration=""
    local output_file=""
    local title=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--duration)
                duration="$2"
                shift 2
                ;;
            -o|--output)
                output_file="$2"
                shift 2
                ;;
            -t|--title)
                title="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    log_info "Starting meeting recording..."

    # Build command arguments
    local record_args=()
    [ -n "$duration" ] && record_args+=("-d" "$duration")
    [ -n "$output_file" ] && record_args+=("-o" "$output_file")
    [ -n "$title" ] && record_args+=("-t" "$title")

    # Run recording and capture output file path
    # Use temp file to avoid command substitution exit on CTRL-C
    local record_result_file="/tmp/shepitnote_record_$$"
    local record_exit_code=0

    "${SCRIPT_DIR}/record_audio.sh" "${record_args[@]}" > "$record_result_file" || record_exit_code=$?

    # Read the output file path
    if [ -f "$record_result_file" ]; then
        output_file=$(cat "$record_result_file")
        rm -f "$record_result_file"
    fi

    # Debug output
    log_debug "Recording exit code: $record_exit_code"
    log_debug "Captured output_file=[$output_file]"
    log_debug "File exists check: $([ -f "$output_file" ] && echo YES || echo NO)"

    if [ -n "$output_file" ] && [ -f "$output_file" ]; then
        log_success "Recording complete: $output_file"
        echo "$output_file"
    else
        log_error "Failed to capture recording output or file doesn't exist"
        return 1
    fi
}

detect_dual_tracks() {
    # Given any track path (voice/system/plain wav or mp3), resolve the meeting
    # base and echo it iff BOTH the voice and system WAV tracks exist. Echoes
    # nothing otherwise, so callers can test with [ -n "$(detect_dual_tracks ...)" ].
    local path="$1"
    local base
    case "$path" in
        *.voice.wav)  base="${path%.voice.wav}" ;;
        *.system.wav) base="${path%.system.wav}" ;;
        *)            base="${path%.*}" ;;
    esac

    if [ -f "${base}.voice.wav" ] && [ -f "${base}.system.wav" ]; then
        echo "$base"
    fi
}

transcribe_meeting() {
    local audio_file="$1"
    shift

    local model="$WHISPER_MODEL"
    local language="$WHISPER_LANGUAGE"
    local initial_prompt="$WHISPER_INITIAL_PROMPT"
    local hotwords="$WHISPER_HOTWORDS"
    local format="txt"
    local output=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -m|--model)
                model="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --initial-prompt)
                initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                hotwords="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -o|--output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Transcribing audio file: $audio_file"
    log_info "Using Whisper model: $model"
    [ -n "$language" ] && log_info "Language: $language"

    # Derive output path, stripping _trimmed suffix so transcripts are named
    # after the meeting base rather than the trimmed audio file.
    if [ -z "$output" ]; then
        local base="${audio_file%.*}"
        base="${base%_trimmed}"
        output="${base}.${format}"
    fi

    local cmd="${NICE[*]} \"$PYTHON\" \"${SCRIPT_DIR}/transcribe.py\" \"$audio_file\" -m $model -f $format -o \"$output\""
    [ -n "$language" ] && cmd="$cmd -l $language"
    # initial_prompt/hotwords are free text (spaces/quotes); %q-quote so they
    # survive the eval as single arguments.
    [ -n "$initial_prompt" ] && cmd="$cmd --initial-prompt $(printf %q "$initial_prompt")"
    [ -n "$hotwords" ] && cmd="$cmd --hotwords $(printf %q "$hotwords")"

    eval $cmd

    if [ -f "$output" ]; then
        log_success "Transcription complete: $output"
        echo "$output"
    else
        log_error "Transcription output file not created: $output"
        return 1
    fi
}

summarize_meeting() {
    local transcription_file="$1"
    shift

    local model="$OLLAMA_MODEL"
    local format="md"
    local output=""
    local language=""
    local glossary_dir="$GLOSSARY_DIR"
    local roster_dir="$ROSTER_DIR"

    while [[ $# -gt 0 ]]; do
        case $1 in
            -o|--ollama)
                model="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --glossary-dir)
                glossary_dir="$2"
                shift 2
                ;;
            --roster-dir)
                roster_dir="$2"
                shift 2
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$transcription_file" ]; then
        log_error "Transcription file not found: $transcription_file"
        exit 1
    fi

    log_info "Summarizing transcription: $transcription_file"
    log_info "Using Ollama model: $model"

    # Derive output path, stripping _trimmed suffix so summaries are named
    # after the meeting base rather than the trimmed file.
    if [ -z "$output" ]; then
        local base="${transcription_file%.*}"
        base="${base%_trimmed}"
        output="${base}_summary.${format}"
    fi

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/summarize.py\" \"$transcription_file\" -m $model -f $format -o \"$output\""
    # Language selects the per-language glossary (issue #8); when empty,
    # summarize.py falls back to the language recorded in the sibling JSON, then
    # to the union of all glossary files. glossary_dir is a path -> quote it.
    [ -n "$language" ] && cmd="$cmd -l $language"
    [ -n "$glossary_dir" ] && cmd="$cmd --glossary-dir $(printf %q "$glossary_dir")"
    # Participant roster (known names + roles) folded into the summary as ground
    # truth; the local-speaker identity comes from MEETING_SELF_NAME/ROLE, which
    # summarize.py also reads from the environment. Paths -> quote them.
    [ -n "$roster_dir" ] && cmd="$cmd --roster-dir $(printf %q "$roster_dir")"
    [ -n "$MEETING_ROSTER" ] && cmd="$cmd --roster $(printf %q "$MEETING_ROSTER")"
    [ -n "$MEETING_SELF_NAME" ] && cmd="$cmd --self-name $(printf %q "$MEETING_SELF_NAME")"
    [ -n "$MEETING_SELF_ROLE" ] && cmd="$cmd --self-role $(printf %q "$MEETING_SELF_ROLE")"

    eval $cmd

    if [ -f "$output" ]; then
        log_success "Summary complete: $output"
        echo "$output"
    fi
}

full_workflow() {
    # Parse arguments for full workflow
    local duration=""
    local whisper_model="$WHISPER_MODEL"
    local whisper_language="$WHISPER_LANGUAGE"
    local whisper_initial_prompt="$WHISPER_INITIAL_PROMPT"
    local whisper_hotwords="$WHISPER_HOTWORDS"
    local ollama_model="$OLLAMA_MODEL"
    local format=""
    local enable_diarization=false
    local num_speakers=""
    local enable_compression=true
    local keep_wav=false
    local clean_all=false
    local title=""
    local enable_trim=true
    local keep_untrimmed=false
    local keep_trimmed=true

    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--duration)
                duration="$2"
                shift 2
                ;;
            -m|--model)
                whisper_model="$2"
                shift 2
                ;;
            -l|--language)
                whisper_language="$2"
                shift 2
                ;;
            --initial-prompt)
                whisper_initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                whisper_hotwords="$2"
                shift 2
                ;;
            -o|--ollama)
                ollama_model="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -t|--title)
                title="$2"
                shift 2
                ;;
            --diarize)
                enable_diarization=true
                shift
                ;;
            -s|--speakers)
                num_speakers="$2"
                shift 2
                ;;
            --no-compress)
                enable_compression=false
                shift
                ;;
            --keep-wav)
                keep_wav=true
                shift
                ;;
            --no-trim)
                enable_trim=false
                shift
                ;;
            --keep-untrimmed)
                keep_untrimmed=true
                shift
                ;;
            --keep-trimmed)
                keep_trimmed=true
                shift
                ;;
            --clean)
                clean_all=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ "$enable_diarization" = true ]; then
        log_info "Starting full meeting workflow with speaker diarization..."
    else
        log_info "Starting full meeting workflow..."
    fi
    echo ""

    # Fail fast if the transcription environment is missing, BEFORE recording, so
    # we never capture a full meeting only to die at the transcribe step.
    check_python_env

    # Record (user-paced, so not part of the timed step count below)
    log_info "Recording audio..."
    local audio_file

    # Record the audio
    # Use a temporary file to communicate the recording path
    local recording_result_file="/tmp/shepitnote_recording_$$"
    local recording_exit_code=0

    # Build record_meeting arguments
    local record_args=()
    [ -n "$duration" ] && record_args+=("-d" "$duration")
    [ -n "$title" ] && record_args+=("-t" "$title")

    if [ -n "$duration" ]; then
        record_meeting "${record_args[@]}" > "$recording_result_file"
        recording_exit_code=$?
    else
        # For open-ended recording, call in a way that captures exit code but continues
        # The || true prevents set -e from exiting, then we check the actual exit code
        record_meeting "${record_args[@]}" > "$recording_result_file" || recording_exit_code=$?

        log_debug "Recording exit code: $recording_exit_code"

        # If recording was stopped (non-zero exit is expected with CTRL-C)
        if [ $recording_exit_code -ne 0 ]; then
            echo "" >&2
            log_info "Recording stopped. Continuing with processing..." >&2
            echo "" >&2
        fi
    fi

    # Read the audio file path from the result file
    if [ -f "$recording_result_file" ]; then
        audio_file=$(cat "$recording_result_file")
        rm -f "$recording_result_file"
    else
        audio_file=""
    fi

    log_debug "Audio file captured: [$audio_file]"

    if [ -z "$audio_file" ] || [ ! -f "$audio_file" ]; then
        log_error "Recording failed or no audio file was created"
        log_error "Exit code was: $recording_exit_code"
        log_error "Audio file variable: [$audio_file]"
        exit 1
    fi

    echo ""

    # Dual-track recording (AUDIO_SOURCE_TYPE=dual): two synced tracks were
    # recorded (voice=You, system=Remote). Detect the pair from the returned
    # voice-track path and process it without diarization.
    local dual_base
    dual_base=$(detect_dual_tracks "$audio_file")
    if [ -n "$dual_base" ]; then
        local dual_args=(-m "$whisper_model")
        [ -n "$whisper_language" ] && dual_args+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && dual_args+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && dual_args+=(--hotwords "$whisper_hotwords")
        [ -n "$ollama_model" ] && dual_args+=(-o "$ollama_model")
        [ "$enable_compression" = false ] && dual_args+=(--no-compress)
        [ "$keep_wav" = true ] && dual_args+=(--keep-wav)
        [ "$clean_all" = true ] && dual_args+=(--clean)
        process_dual_meeting "$dual_base" "${dual_args[@]}"
        return 0
    fi

    if [ "$enable_diarization" = true ]; then
        # Diarization workflow. Six fixed steps (diarize, transcribe, merge,
        # label, apply, summarize) plus a final compress/clean step unless both
        # compression and --clean are off.
        local _diar_total=6
        { [ "$clean_all" = true ] || [ "$enable_compression" = true ]; } && _diar_total=$((_diar_total + 1))
        steps_init "$_diar_total"

        # Step: Diarize
        step "Identifying speakers"
        local speakers_file
        if [ -n "$num_speakers" ]; then
            speakers_file=$(diarize_meeting "$audio_file" -s "$num_speakers")
        else
            speakers_file=$(diarize_meeting "$audio_file")
        fi

        if [ -z "$speakers_file" ] || [ ! -f "$speakers_file" ]; then
            log_error "Diarization failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Transcribe (as JSON for merging)
        step "Transcribing audio"
        local base="${audio_file%.*}"
        local transcription_json="${base}.json"

        local transcribe_cmd=("${NICE[@]}" "$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$audio_file" -m "$whisper_model" -f json -o "$transcription_json")
        [ -n "$whisper_language" ] && transcribe_cmd+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && transcribe_cmd+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && transcribe_cmd+=(--hotwords "$whisper_hotwords")
        "${transcribe_cmd[@]}"

        if [ ! -f "$transcription_json" ]; then
            log_error "Transcription failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Merge diarization + transcription
        step "Merging speaker info with transcription"
        local diarized_file="${base}_diarized.json"

        "$PYTHON" "${SCRIPT_DIR}/merge_diarization.py" "$speakers_file" "$transcription_json" -o "$diarized_file"

        if [ ! -f "$diarized_file" ]; then
            log_error "Merge failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Label speakers interactively
        step "Label speakers with their names"
        echo ""

        # Call label_speakers without command substitution to allow interactive input
        label_speakers "$diarized_file"

        # Determine output file manually
        local base="${diarized_file%_diarized.json}"
        local labeled_file="${base}_speakers_labeled.json"

        if [ ! -f "$labeled_file" ]; then
            log_error "Labeling failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Apply labels to create final transcript
        step "Creating final transcript with speaker names"
        local transcription_file=$(apply_speaker_labels "$labeled_file" -f txt)

        if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
            log_error "Apply labels failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Summarize
        step "Generating summary"
        local summary_file
        local summarize_args=()
        [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
        [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
        summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

        if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
            log_error "Summarization failed"
            exit 1
        fi
        step_done

        echo ""

        # Step: Compress audio and cleanup
        if [ "$clean_all" = true ]; then
            step "Removing all audio files"
            # Delete both WAV and MP3 if they exist
            [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
            local mp3_file="${audio_file%.wav}.mp3"
            [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
            audio_file="(deleted)"
            step_done
            echo ""
        elif [ "$enable_compression" = true ]; then
            step "Compressing audio to MP3"
            local mp3_file
            if [ "$keep_wav" = true ]; then
                mp3_file=$(compress_audio "$audio_file")
            else
                # Default: delete WAV after compression
                mp3_file=$(compress_audio "$audio_file" --delete-wav)
            fi

            if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                audio_file="$mp3_file"
            fi
            step_done
            echo ""
        fi

        steps_total_done
        log_success "Complete workflow with diarization finished!"
        echo ""
        echo "Files generated:"
        echo "  Audio:          $audio_file"
        echo "  Diarization:    $speakers_file"
        echo "  Labeled:        $labeled_file"
        echo "  Transcription:  $transcription_file"
        echo "  Summary:        $summary_file"
    else
        # Standard workflow without diarization. Two fixed steps (transcribe,
        # summarize) plus optional compress and trim steps.
        local _std_total=2
        { [ "$clean_all" = true ] || [ "$enable_compression" = true ]; } && _std_total=$((_std_total + 1))
        [ "$enable_trim" = true ] && _std_total=$((_std_total + 1))
        steps_init "$_std_total"

        # Step: Compress WAV → MP3 and delete WAV
        local mp3_file=""
        local transcribe_source="$audio_file"
        if [ "$clean_all" = true ]; then
            step "Skipping compression (--clean mode, audio will be deleted)"
            step_done
            echo ""
        elif [ "$enable_compression" = true ]; then
            step "Compressing audio to MP3"
            if [ "$keep_wav" = true ]; then
                mp3_file=$(compress_audio "$audio_file")
            else
                mp3_file=$(compress_audio "$audio_file" --delete-wav)
            fi
            if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                transcribe_source="$mp3_file"
            fi
            step_done
            echo ""
        fi

        # Step: Trim silent tail
        local trimmed_file=""
        if [ "$enable_trim" = true ] && [ -f "$transcribe_source" ]; then
            step "Trimming silent tail"
            trimmed_file=$(trim_audio "$transcribe_source")
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                transcribe_source="$trimmed_file"
            fi
            step_done
            echo ""
        fi

        # Step: Transcribe
        step "Transcribing audio"
        local transcription_file
        local transcribe_args=()
        [ -n "$whisper_model" ] && transcribe_args+=(-m "$whisper_model")
        [ -n "$whisper_language" ] && transcribe_args+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && transcribe_args+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && transcribe_args+=(--hotwords "$whisper_hotwords")
        transcription_file=$(transcribe_meeting "$transcribe_source" "${transcribe_args[@]}")

        log_debug "Transcription file captured: [$transcription_file]"

        if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
            log_error "Transcription failed - file not found: $transcription_file"
            exit 1
        fi
        step_done

        echo ""

        # Step: Summarize
        step "Generating summary"
        local summary_file
        local summarize_args=()
        [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
        [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
        summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

        if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
            log_error "Summarization failed"
            exit 1
        fi
        step_done

        echo ""

        # Cleanup audio
        if [ "$clean_all" = true ]; then
            log_info "Removing all audio files..."
            [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
            [ -n "$mp3_file" ] && [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
            [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && rm "$trimmed_file" && log_success "Deleted: $trimmed_file"
            audio_file="(deleted)"
            echo ""
        else
            # Delete untrimmed MP3 unless --keep-untrimmed
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                if [ "$keep_untrimmed" = false ]; then
                    rm "$mp3_file" && log_info "Deleted untrimmed: $mp3_file (use --keep-untrimmed to keep)"
                fi
            fi
            # Delete trimmed MP3 if --keep-trimmed is false
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                if [ "$keep_trimmed" = false ]; then
                    rm "$trimmed_file" && log_info "Deleted trimmed audio: $trimmed_file"
                fi
            fi
        fi

        steps_total_done
        log_success "Complete workflow finished!"
        echo ""
        echo "Files generated:"
        [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && echo "  Audio (trimmed):    $trimmed_file"
        [ -n "$mp3_file" ] && [ -f "$mp3_file" ] && echo "  Audio (full):       $mp3_file"
        echo "  Transcription:      $transcription_file"
        echo "  Summary:            $summary_file"

        run_post_summary_hook "$summary_file" && \
            touch "${summary_file%_summary.md}.hook_done" || true
    fi
}

process_dual_meeting() {
    # Process a dual-track recording: transcribe the voice (You) and system
    # (Remote) tracks separately, tag each segment by track of origin, merge by
    # timestamp, then render and summarize. The You-vs-Remote split comes from
    # the two physical tracks — no diarization needed for that.
    #
    # Optionally (issue #11, opt-in via DUAL_REMOTE_DIARIZATION=true) the system
    # track alone is diarized so several people on the far side become
    # [Remote 1] / [Remote 2] / ... The microphone track is never diarized, so
    # [You] stays clean regardless. This is best-effort: any failure (no
    # HF_TOKEN, pyannote missing, model download error) falls back to a single
    # [Remote] label so the meeting still completes.
    local base="$1"
    shift

    local model="$WHISPER_MODEL"
    local language="$WHISPER_LANGUAGE"
    local initial_prompt="$WHISPER_INITIAL_PROMPT"
    local hotwords="$WHISPER_HOTWORDS"
    local ollama_model="$OLLAMA_MODEL"
    local enable_compression=true
    local keep_wav=false
    local clean_all=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -m|--model)
                model="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --initial-prompt)
                initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                hotwords="$2"
                shift 2
                ;;
            -o|--ollama)
                ollama_model="$2"
                shift 2
                ;;
            --no-compress)
                enable_compression=false
                shift
                ;;
            --keep-wav)
                keep_wav=true
                shift
                ;;
            --clean)
                clean_all=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    # Resolve each track to its WAV if present, else the compressed MP3. A
    # reprocess of an already-compressed meeting has only .mp3 tracks left, and
    # transcribe.py/diarize.py read MP3 fine (via ffmpeg), so no re-decode is
    # needed. WAV is preferred when both exist. voice_wav/system_wav keep pointing
    # at the .wav specifically, so the compression step below only ever touches a
    # real WAV (and skips a track that is already MP3).
    local voice_wav="${base}.voice.wav"
    local system_wav="${base}.system.wav"
    local voice_src="$voice_wav"
    local system_src="$system_wav"
    [ -f "$voice_src" ]  || voice_src="${base}.voice.mp3"
    [ -f "$system_src" ] || system_src="${base}.system.mp3"

    if [ ! -f "$voice_src" ] || [ ! -f "$system_src" ]; then
        log_error "Dual tracks not found for: $(basename "$base") (need .voice + .system as .wav or .mp3)"
        return 1
    fi

    log_info "Processing dual-track recording: $(basename "$base")"
    log_info "Using Whisper model: $model"
    [ -n "$language" ] && log_info "Language: $language"
    echo ""

    # Fixed steps: transcribe voice + transcribe system + merge + apply +
    # summarize. Optionally add a Remote-diarization step and a compress/clean
    # step.
    local _dual_total=5
    [ "${DUAL_REMOTE_DIARIZATION:-false}" = "true" ] && _dual_total=$((_dual_total + 1))
    { [ "$clean_all" = true ] || [ "$enable_compression" = true ]; } && _dual_total=$((_dual_total + 1))
    steps_init "$_dual_total"

    # Step: Transcribe the voice track (You).
    step "Transcribing voice track (You)"
    local voice_json="${base}.voice.json"
    local voice_cmd=("${NICE[@]}" "$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$voice_src" -m "$model" -f json -o "$voice_json")
    [ -n "$language" ] && voice_cmd+=(-l "$language")
    [ -n "$initial_prompt" ] && voice_cmd+=(--initial-prompt "$initial_prompt")
    [ -n "$hotwords" ] && voice_cmd+=(--hotwords "$hotwords")
    "${voice_cmd[@]}"

    if [ ! -f "$voice_json" ]; then
        log_error "Voice track transcription failed"
        return 1
    fi
    step_done
    echo ""

    # Step: Transcribe the system track (Remote).
    step "Transcribing system track (Remote)"
    local system_json="${base}.system.json"
    local system_cmd=("${NICE[@]}" "$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$system_src" -m "$model" -f json -o "$system_json")
    [ -n "$language" ] && system_cmd+=(-l "$language")
    [ -n "$initial_prompt" ] && system_cmd+=(--initial-prompt "$initial_prompt")
    [ -n "$hotwords" ] && system_cmd+=(--hotwords "$hotwords")
    "${system_cmd[@]}"

    if [ ! -f "$system_json" ]; then
        log_error "System track transcription failed"
        return 1
    fi
    step_done
    echo ""

    # Step (opt-in): diarize the system (Remote) track so multiple far-side
    # speakers split into [Remote 1] / [Remote 2] / ... Best-effort — any
    # failure falls back to a single [Remote] label and the meeting continues.
    local system_diar_json=""
    if [ "${DUAL_REMOTE_DIARIZATION:-false}" = "true" ]; then
        step "Diarizing system track (splitting Remote per speaker)"
        if [ -z "${HF_TOKEN:-}" ]; then
            log_warn "DUAL_REMOTE_DIARIZATION is on but HF_TOKEN is not set — keeping a single [Remote] label."
        else
            local diar_out="${base}.system_speakers.json"
            local diar_cmd=("${NICE[@]}" "$PYTHON" "${SCRIPT_DIR}/diarize.py" "$system_src" -o "$diar_out")
            [ -n "${DUAL_REMOTE_SPEAKERS:-}" ]     && diar_cmd+=(-s "$DUAL_REMOTE_SPEAKERS")
            [ -n "${DUAL_REMOTE_MIN_SPEAKERS:-}" ] && diar_cmd+=(--min-speakers "$DUAL_REMOTE_MIN_SPEAKERS")
            [ -n "${DUAL_REMOTE_MAX_SPEAKERS:-}" ] && diar_cmd+=(--max-speakers "$DUAL_REMOTE_MAX_SPEAKERS")
            # Guarded in an `if` so a nonzero exit is caught (not fatal under set -e).
            if "${diar_cmd[@]}" && [ -f "$diar_out" ]; then
                system_diar_json="$diar_out"
                log_success "Remote track diarized: $(basename "$diar_out")"
            else
                log_warn "Remote-track diarization failed — keeping a single [Remote] label."
            fi
        fi
        step_done
        echo ""
    fi

    # Step: Merge tracks — label by origin (You vs Remote). When a system-track
    # diarization is available, the Remote side is split into per-speaker labels.
    step "Merging tracks (You vs Remote)"
    local labeled_file="${base}_speakers_labeled.json"
    local merge_cmd=("$PYTHON" "${SCRIPT_DIR}/merge_tracks.py"
        --voice "$voice_json" --system "$system_json"
        --audio-file "$(basename "$voice_src")" -o "$labeled_file")
    [ -n "$system_diar_json" ] && merge_cmd+=(--system-diarization "$system_diar_json")
    "${merge_cmd[@]}"

    if [ ! -f "$labeled_file" ]; then
        log_error "Track merge failed"
        return 1
    fi
    step_done
    echo ""

    # Step: Render final transcript named after the meeting base so status/
    # list see meeting_TS.txt.
    step "Creating final transcript with You/Remote labels"
    local transcription_file="${base}.txt"
    apply_speaker_labels "$labeled_file" -f txt -o "$transcription_file" >/dev/null

    if [ ! -f "$transcription_file" ]; then
        log_error "Apply labels failed"
        return 1
    fi
    step_done
    echo ""

    # Step: Summarize.
    step "Generating summary"
    local summary_file
    local summarize_args=()
    [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
    [ -n "$language" ] && summarize_args+=(-l "$language")
    summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

    if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
        log_error "Summarization failed"
        return 1
    fi
    step_done
    echo ""

    # Step: Compress or clean each track. Silent-tail trimming is skipped in
    # dual mode — per-track trimming would desync turn ordering.
    local voice_audio="$voice_src"
    local system_audio="$system_src"
    if [ "$clean_all" = true ]; then
        step "Removing all audio files"
        [ -f "$voice_wav" ]  && rm "$voice_wav"  && log_success "Deleted: $voice_wav"
        [ -f "$system_wav" ] && rm "$system_wav" && log_success "Deleted: $system_wav"
        [ -f "${base}.voice.mp3" ]  && rm "${base}.voice.mp3"  && log_success "Deleted: ${base}.voice.mp3"
        [ -f "${base}.system.mp3" ] && rm "${base}.system.mp3" && log_success "Deleted: ${base}.system.mp3"
        voice_audio="(deleted)"
        system_audio="(deleted)"
        step_done
        echo ""
    elif [ "$enable_compression" = true ]; then
        step "Compressing tracks to MP3"
        local mp3
        # Only compress a track that still exists as WAV — a reprocess may already
        # have MP3s (nothing to do), and compressing an MP3 into an MP3 is pointless.
        local delete_flag=(); [ "$keep_wav" = false ] && delete_flag=(--delete-wav)
        if [ -f "$voice_wav" ]; then
            mp3=$(compress_audio "$voice_wav" "${delete_flag[@]}")
            [ -n "$mp3" ] && [ -f "$mp3" ] && voice_audio="$mp3"
        fi
        if [ -f "$system_wav" ]; then
            mp3=$(compress_audio "$system_wav" "${delete_flag[@]}")
            [ -n "$mp3" ] && [ -f "$mp3" ] && system_audio="$mp3"
        fi
        step_done
        echo ""
    fi

    steps_total_done
    log_success "Dual-track processing complete!"
    echo ""
    echo "Files generated:"
    echo "  Audio (voice/You):     $voice_audio"
    echo "  Audio (system/Remote): $system_audio"
    echo "  Labeled:               $labeled_file"
    echo "  Transcription:         $transcription_file"
    echo "  Summary:               $summary_file"

    run_post_summary_hook "$summary_file" && \
        touch "${summary_file%_summary.md}.hook_done" || true
}

reprocess_meeting() {
    # Reprocess an ENTIRE meeting by id: re-run transcription + summary with the
    # options given, overwriting meeting_<ts>.txt and meeting_<ts>_summary.md.
    #   * Dual (You/Remote) meetings: BOTH tracks are re-transcribed, merged and
    #     summarized. Works from .wav OR .mp3, so an already-compressed meeting
    #     reprocesses without re-recording; the audio is never modified or deleted.
    #   * Single-track meetings: the one track is re-transcribed and summarized.
    # Publishing is OFF unless --publish is passed, so you can freely A/B different
    # Whisper/Ollama models and languages. --cloud / --no-cloud / --no-diarize are
    # global flags (stripped before dispatch) and compose with this command too.
    local meeting_id=""
    local do_publish=false
    local model="$WHISPER_MODEL"
    local language="$WHISPER_LANGUAGE"
    local initial_prompt="$WHISPER_INITIAL_PROMPT"
    local hotwords="$WHISPER_HOTWORDS"
    local ollama_model="$OLLAMA_MODEL"

    while [[ $# -gt 0 ]]; do
        case $1 in
            -m|--model)       model="$2"; shift 2 ;;
            -l|--language)    language="$2"; shift 2 ;;
            --initial-prompt) initial_prompt="$2"; shift 2 ;;
            --hotwords)       hotwords="$2"; shift 2 ;;
            -o|--ollama)      ollama_model="$2"; shift 2 ;;
            --publish)        do_publish=true; shift ;;
            -h|--help)        print_usage; return 0 ;;
            -*)               log_warn "Ignoring unsupported process-meeting option: $1"; shift ;;
            *)                [ -z "$meeting_id" ] && meeting_id="$1"; shift ;;
        esac
    done

    if [ -z "$meeting_id" ]; then
        log_error "Usage: $(basename "$0") process-meeting <meeting-id> [options]"
        log_error "  meeting-id: folder name (meeting_YYYYMMDD_HHMMSS), bare timestamp"
        log_error "  (YYYYMMDD_HHMMSS), or a path to the meeting folder or a file in it."
        return 1
    fi

    # Resolve the meeting directory from: a folder path, a file inside it, the
    # full folder name, or a bare timestamp.
    local meeting_dir=""
    if [ -d "$meeting_id" ]; then
        meeting_dir="$meeting_id"
    elif [ -f "$meeting_id" ]; then
        meeting_dir="$(dirname "$meeting_id")"
    else
        local name d
        name="$(basename "${meeting_id%/}")"
        case "$name" in meeting_*) : ;; *) name="meeting_${name}" ;; esac
        for d in "$OUTPUT_DIR"/*/"$name"; do
            [ -d "$d" ] && { meeting_dir="$d"; break; }
        done
    fi

    if [ -z "$meeting_dir" ] || [ ! -d "$meeting_dir" ]; then
        log_error "Meeting not found: $meeting_id (looked under $OUTPUT_DIR)"
        return 1
    fi

    local base="${meeting_dir}/$(basename "$meeting_dir")"

    # Publishing is opt-in. run_post_summary_hook honors this guard var, which is
    # NOT settable from .shepitnoterc, so it survives the config re-source in the
    # summarize worker. Export (or clear) it before any processing runs.
    if [ "$do_publish" = true ]; then
        unset HUSHNOTE_SKIP_POST_SUMMARY_HOOK
        log_info "Reprocessing meeting: $(basename "$meeting_dir")  (publishing: ON)"
    else
        export HUSHNOTE_SKIP_POST_SUMMARY_HOOK=1
        log_info "Reprocessing meeting: $(basename "$meeting_dir")  (publishing: off — pass --publish to enable)"
    fi
    log_info "Whisper model: $model  |  Ollama model: $ollama_model${language:+  |  Language: $language}"
    echo ""

    # Dual meeting? Both tracks present (as .wav or .mp3) -> full You/Remote reprocess.
    if { [ -f "${base}.voice.wav" ] || [ -f "${base}.voice.mp3" ]; } && \
       { [ -f "${base}.system.wav" ] || [ -f "${base}.system.mp3" ]; }; then
        local dual_args=(-m "$model" --no-compress)
        [ -n "$language" ]       && dual_args+=(-l "$language")
        [ -n "$initial_prompt" ] && dual_args+=(--initial-prompt "$initial_prompt")
        [ -n "$hotwords" ]       && dual_args+=(--hotwords "$hotwords")
        [ -n "$ollama_model" ]   && dual_args+=(-o "$ollama_model")
        local rc=0
        process_dual_meeting "$base" "${dual_args[@]}" || rc=$?
        return $rc
    fi

    # Not a full dual pair. Find a single track to reprocess, in order: a plain
    # single-track recording, then a lone surviving You or Remote track (a dual
    # meeting can end up with just one track if the other was lost/deleted).
    local audio="" missing_note="" cand
    for cand in "${base}.wav" "${base}.mp3"; do
        [ -f "$cand" ] && { audio="$cand"; break; }
    done
    if [ -z "$audio" ]; then
        for cand in "${base}.voice.wav" "${base}.voice.mp3"; do
            [ -f "$cand" ] && { audio="$cand"; missing_note="only the voice (You) track is present — the system (Remote) track is missing"; break; }
        done
    fi
    if [ -z "$audio" ]; then
        for cand in "${base}.system.wav" "${base}.system.mp3"; do
            [ -f "$cand" ] && { audio="$cand"; missing_note="only the system (Remote) track is present — the voice (You) track is missing"; break; }
        done
    fi
    if [ -z "$audio" ]; then
        log_error "No audio found to reprocess in $(basename "$meeting_dir")"
        log_error "(expected $(basename "$base").wav/.mp3, or a .voice + .system dual pair)"
        return 1
    fi
    [ -n "$missing_note" ] && log_warn "$missing_note; reprocessing that track alone."

    log_info "Single-track reprocess: $(basename "$audio")"
    steps_init 2

    # Always write the transcript to the meeting base name (meeting_<ts>.txt), not
    # after the source track's filename, so status/list/publishers recognize it.
    local transcription_file="${base}.txt"
    step "Transcribing audio"
    local transcribe_args=(-m "$model" -o "$transcription_file")
    [ -n "$language" ]       && transcribe_args+=(-l "$language")
    [ -n "$initial_prompt" ] && transcribe_args+=(--initial-prompt "$initial_prompt")
    [ -n "$hotwords" ]       && transcribe_args+=(--hotwords "$hotwords")
    transcribe_meeting "$audio" "${transcribe_args[@]}" >/dev/null || {
        log_error "Transcription failed"
        return 1
    }
    [ -f "$transcription_file" ] || { log_error "Transcription failed"; return 1; }
    step_done
    echo ""

    step "Generating summary"
    local summarize_args=()
    [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
    [ -n "$language" ]     && summarize_args+=(-l "$language")
    local summary_file=""
    summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}") || {
        log_error "Summarization failed"
        return 1
    }
    [ -f "$summary_file" ] || { log_error "Summarization failed"; return 1; }
    step_done
    echo ""

    steps_total_done
    log_success "Reprocessing complete!"
    echo ""
    echo "Files generated:"
    echo "  Transcription:  $transcription_file"
    echo "  Summary:        $summary_file"

    run_post_summary_hook "$summary_file" && \
        touch "${summary_file%_summary.md}.hook_done" || true
}

diarize_meeting() {
    local audio_file="$1"
    shift

    local speakers=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--speakers)
                speakers="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Identifying speakers in: $audio_file"

    local cmd="${NICE[*]} \"$PYTHON\" \"${SCRIPT_DIR}/diarize.py\" \"$audio_file\""
    [ -n "$speakers" ] && cmd="$cmd -s $speakers"

    eval $cmd

    # Determine output file
    local base="${audio_file%.*}"
    local output="${base}_speakers.json"

    if [ -f "$output" ]; then
        log_success "Diarization complete: $output"
        echo "$output"
    fi
}

label_speakers() {
    local diarized_file="$1"
    shift

    if [ ! -f "$diarized_file" ]; then
        log_error "Diarized file not found: $diarized_file"
        exit 1
    fi

    log_info "Labeling speakers in: $diarized_file"
    echo ""

    # Run label.py interactively (don't capture output)
    "$PYTHON" "${SCRIPT_DIR}/label.py" "$diarized_file" </dev/tty

    # Determine output file
    local base="${diarized_file%_diarized.json}"
    local output="${base}_speakers_labeled.json"

    if [ -f "$output" ]; then
        echo ""
        log_success "Labeling complete: $output"
        echo "$output"
    fi
}

apply_speaker_labels() {
    local labeled_file="$1"
    shift

    local format="txt"
    local output=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--format)
                format="$2"
                shift 2
                ;;
            -o|--output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$labeled_file" ]; then
        log_error "Labeled file not found: $labeled_file"
        exit 1
    fi

    log_info "Applying labels to transcript: $labeled_file"

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/apply_labels.py\" \"$labeled_file\" -f $format"
    [ -n "$output" ] && cmd="$cmd -o \"$output\""

    eval $cmd

    # Determine output file
    if [ -z "$output" ]; then
        # Extract base name from labeled file
        local base=$(basename "$labeled_file" "_speakers_labeled.json")
        base="${base%.json}"
        output="$(dirname "$labeled_file")/${base}.${format}"
    fi

    if [ -f "$output" ]; then
        log_success "Transcript complete: $output"
        echo "$output"
    fi
}

compress_audio() {
    local audio_file="$1"
    shift

    local delete_wav=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --delete-wav|--clean)
                delete_wav=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Compressing audio: $audio_file"

    local compress_args=("${SCRIPT_DIR}/compress.sh" "$audio_file")
    [ "$delete_wav" = true ] && compress_args+=(--delete-wav)

    local mp3_file
    mp3_file=$("${compress_args[@]}")

    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
        log_success "Compression complete: $mp3_file"
        echo "$mp3_file"
    fi
}

trim_audio() {
    local audio_file="$1"
    shift

    local noise_threshold="${TRIM_NOISE_DB:--35}"
    local min_silence="${TRIM_MIN_SILENCE:-60}"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --noise)
                noise_threshold="$2"
                shift 2
                ;;
            --min-silence)
                min_silence="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Scanning for silent tail: $audio_file (noise=${noise_threshold}dB, min-silence=${min_silence}s)"

    local total_duration
    total_duration=$(ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)

    if [ -z "$total_duration" ]; then
        log_warn "Could not determine duration, skipping trim"
        echo "$audio_file"
        return 0
    fi

    local total_int
    total_int=$(python3 -c "print(int(float('$total_duration')))")

    # Window size for each probe: 5 minutes
    local window=300

    # Binary search for the last position that contains content.
    # lo = last known position with content, hi = first known silent position.
    # We probe the midpoint each iteration.
    local lo=0
    local hi=$total_int

    # Confirm content exists at the very start before searching
    local first_output
    first_output=$(ffmpeg -ss 0 -t $window -i "$audio_file" \
        -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

    local first_sil_at_start
    first_sil_at_start=$(echo "$first_output" | grep -oP 'silence_start: \K[\d.]+' | head -1 || true)

    local start_has_content=false
    if [ -z "$first_sil_at_start" ]; then
        start_has_content=true
    elif python3 -c "exit(0 if float('$first_sil_at_start') > 5 else 1)" 2>/dev/null; then
        start_has_content=true
    fi

    if [ "$start_has_content" = false ]; then
        log_warn "No content found in first ${window}s — skipping trim"
        echo "$audio_file"
        return 0
    fi

    log_debug "Binary search: lo=${lo}s hi=${hi}s total=${total_int}s"

    local iterations=0
    while [ $((hi - lo)) -gt $window ] && [ $iterations -lt 12 ]; do
        iterations=$((iterations + 1))
        local mid=$(( (lo + hi) / 2 ))

        local output
        output=$(ffmpeg -ss "$mid" -t $window -i "$audio_file" \
            -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

        # Window has content if: no silence detected at all, or first silence
        # starts more than 5s in (meaning content preceded it).
        # A silence_end alone does NOT mean content — it just means the silence
        # block closed at the window boundary (entire window was silent).
        local has_content=false
        local first_sil
        first_sil=$(echo "$output" | grep -oP 'silence_start: \K[\d.]+' | head -1 || true)

        if [ -z "$first_sil" ]; then
            has_content=true
        elif python3 -c "exit(0 if float('$first_sil') > 5 else 1)" 2>/dev/null; then
            has_content=true
        fi

        if [ "$has_content" = true ]; then
            lo=$mid
            log_debug "  mid=${mid}s → content found, lo=${lo}s"
        else
            hi=$mid
            log_debug "  mid=${mid}s → silent, hi=${hi}s"
        fi
    done

    # lo is the last window start known to have content.
    # Scan that window precisely to find where content ends within it.
    local final_output
    final_output=$(ffmpeg -ss "$lo" -t $window -i "$audio_file" \
        -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

    local last_silence_start_in_window
    last_silence_start_in_window=$(echo "$final_output" | grep -oP 'silence_start: \K[\d.]+' | tail -1 || true)

    local last_content_end
    if [ -n "$last_silence_start_in_window" ]; then
        # Add 2s buffer so we don't cut the last word
        last_content_end=$(python3 -c "print(min(float('$total_duration'), $lo + float('$last_silence_start_in_window') + 2))")
    else
        # No silence in final window — content runs to end of it
        last_content_end=$(python3 -c "print(min(float('$total_duration'), $lo + $window))")
    fi

    local total_min
    total_min=$(python3 -c "print(round(float('$total_duration') / 60, 1))")
    local trim_min
    trim_min=$(python3 -c "print(round(float('$last_content_end') / 60, 1))")
    local saved_min
    saved_min=$(python3 -c "print(round((float('$total_duration') - float('$last_content_end')) / 60, 1))")

    if python3 -c "exit(0 if float('$saved_min') < 1 else 1)" 2>/dev/null; then
        log_info "Less than 1 min to trim — skipping (${total_min}min recording)"
        echo "$audio_file"
        return 0
    fi

    log_info "Trimming ${total_min}min → ${trim_min}min (saves ${saved_min}min)"

    local ext="${audio_file##*.}"
    local base="${audio_file%.*}"
    local trimmed_file="${base}_trimmed.${ext}"

    ffmpeg -i "$audio_file" -t "$last_content_end" -codec:a copy -y "$trimmed_file" 2>/dev/null

    if [ ! -f "$trimmed_file" ]; then
        log_error "Trim failed"
        return 1
    fi

    log_success "Trimmed audio: $trimmed_file"
    echo "$trimmed_file"
}

clean_audio() {
    local audio_file="$1"

    # Determine base path and possible audio files
    local base_path="${audio_file%.wav}"
    base_path="${base_path%.mp3}"
    local wav_file="${base_path}.wav"
    local mp3_file="${base_path}.mp3"

    local deleted_count=0

    log_info "Removing all audio files for: $(basename "$base_path")"

    # Delete WAV if exists
    if [ -f "$wav_file" ]; then
        rm "$wav_file"
        log_success "Deleted: $wav_file"
        deleted_count=$((deleted_count + 1))
    fi

    # Delete MP3 if exists
    if [ -f "$mp3_file" ]; then
        rm "$mp3_file"
        log_success "Deleted: $mp3_file"
        deleted_count=$((deleted_count + 1))
    fi

    if [ $deleted_count -eq 0 ]; then
        log_warn "No audio files found to delete"
        exit 1
    fi

    log_info "Text files (transcripts, summaries) preserved"
}

list_recordings() {
    log_info "Recordings in $OUTPUT_DIR:"
    echo ""

    if [ ! -d "$OUTPUT_DIR" ] || [ -z "$(ls -A "$OUTPUT_DIR" 2>/dev/null)" ]; then
        log_warn "No recordings found"
        exit 0
    fi

    local count=0
    # Iterate through date directories (YYYYMMDD format)
    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        if [ ! -d "$date_dir" ]; then
            continue
        fi

        local date_name=$(basename "$date_dir")
        local formatted_date="${date_name:0:4}-${date_name:4:2}-${date_name:6:2}"

        # Iterate through meeting directories within each date
        for meeting_dir in "$date_dir"/meeting_*; do
            if [ ! -d "$meeting_dir" ]; then
                continue
            fi

            # Find the .wav file in the meeting directory
            local wav_file=$(find "$meeting_dir" -name "*.wav" -type f | head -1)
            if [ -z "$wav_file" ] || [ ! -f "$wav_file" ]; then
                continue
            fi

            count=$((count + 1))
            local size=$(du -h "$wav_file" | cut -f1)
            local timestamp=$(stat -c %y "$wav_file" | cut -d' ' -f1,2 | cut -d'.' -f1)
            local meeting_name=$(basename "$meeting_dir")

            # Try to load title from metadata file
            local base="${wav_file%.*}"
            local metadata_file="${base}_metadata.json"
            local title=""
            if [ -f "$metadata_file" ]; then
                title=$(grep -o '"title"[[:space:]]*:[[:space:]]*"[^"]*"' "$metadata_file" | sed 's/"title"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/')
            fi

            if [ -n "$title" ]; then
                echo "$count. $formatted_date - $title"
            else
                echo "$count. $formatted_date - $(basename "$meeting_name")"
            fi
            echo "   Path: $meeting_dir"
            echo "   Size: $size | Date: $timestamp"

            # Check for associated files
            [ -f "${base}.txt" ] && echo "   ✓ Transcription available"
            [ -f "${base}_speakers.json" ] && echo "   ✓ Diarization available"
            [ -f "${base}_summary.md" ] && echo "   ✓ Summary available"
            echo ""
        done
    done

    if [ $count -eq 0 ]; then
        log_warn "No recordings found"
    fi
}

run_post_summary_hook() {
    local summary_file="$1"

    # The guided `meeting` flow (issue #5) keeps publishing confirm-gated: it runs
    # `process` with HUSHNOTE_SKIP_POST_SUMMARY_HOOK=1 so the automatic hook never
    # fires here. Sourcing .shepitnoterc in the child would re-populate
    # POST_SUMMARY_HOOK, so a dedicated guard var (not settable from config) is the
    # reliable suppressor. Return non-zero so the caller does NOT write .hook_done:
    # the meeting is left "hook pending" and the UI (or a later explicit catchup)
    # owns the publish decision. Nothing is published on this path.
    if [ -n "${HUSHNOTE_SKIP_POST_SUMMARY_HOOK:-}" ]; then
        log_info "Post-summary hook suppressed (interactive review will confirm publishing)"
        return 1
    fi

    if [ -z "$POST_SUMMARY_HOOK" ]; then
        return 0
    fi

    if [ ! -x "$POST_SUMMARY_HOOK" ]; then
        log_warn "POST_SUMMARY_HOOK is set but not executable: $POST_SUMMARY_HOOK"
        return 1
    fi

    log_info "Running post-summary hook: $POST_SUMMARY_HOOK"
    "$POST_SUMMARY_HOOK" "$summary_file"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log_warn "Post-summary hook exited with code $exit_code"
        return 1
    fi

    log_success "Post-summary hook completed"
    return 0
}

catchup_recordings() {
    local dry_run=false
    local process_args=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run)
                dry_run=true
                shift
                ;;
            *)
                # Pass remaining args through to process (e.g. --no-trim, -m small)
                process_args+=("$1")
                shift
                ;;
        esac
    done

    if [ ! -d "$OUTPUT_DIR" ]; then
        log_warn "No recordings directory found: $OUTPUT_DIR"
        exit 0
    fi

    local processed=0 hooked=0 failed=0

    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        [ -d "$date_dir" ] || continue

        for meeting_dir in "$date_dir"/meeting_*; do
            [ -d "$meeting_dir" ] || continue

            local base_name
            base_name=$(basename "$meeting_dir")
            local base="${meeting_dir}/${base_name}"

            local wav_file="${base}.wav"
            local mp3_file="${base}.mp3"
            # Dual-track recordings (AUDIO_SOURCE_TYPE=dual) never create the
            # mixed ${base}.wav; they leave ${base}.voice.wav + ${base}.system.wav
            # on disk until processed. Recognise that pair so catchup does not
            # silently skip a pending dual meeting.
            local dual_voice="${base}.voice.wav"
            local has_dual=false
            [ -f "$dual_voice" ] && [ -f "${base}.system.wav" ] && has_dual=true
            local summary_file="${base}_summary.md"
            local hook_done_file="${base}.hook_done"

            # Determine title for log messages
            local title="$base_name"
            local metadata_file="${base}_metadata.json"
            if [ -f "$metadata_file" ]; then
                local meta_title
                meta_title=$(python3 -c "
import json, sys
try:
    d = json.load(open('$metadata_file'))
    print(d.get('title',''))
except Exception:
    pass
" 2>/dev/null)
                [ -n "$meta_title" ] && title="$meta_title"
            fi

            # Case 1: has audio but no summary → needs processing
            if [ ! -f "$summary_file" ] && ( [ -f "$wav_file" ] || [ -f "$mp3_file" ] || $has_dual ); then
                local audio_file=""
                [ -f "$wav_file" ] && audio_file="$wav_file"
                [ -f "$mp3_file" ] && [ -z "$audio_file" ] && audio_file="$mp3_file"
                # For a dual recording, hand `process` the voice track path; its
                # detect_dual_tracks resolves the pair and routes to dual processing.
                $has_dual && [ -z "$audio_file" ] && audio_file="$dual_voice"

                log_info "[$title] Needs processing: $(basename "$audio_file")"
                processed=$((processed + 1))

                if [ "$dry_run" = true ]; then
                    continue
                fi

                "$0" process "$audio_file" "${process_args[@]}"
                local exit_code=$?
                if [ $exit_code -ne 0 ]; then
                    log_warn "[$title] Processing failed (exit $exit_code)"
                    failed=$((failed + 1))
                    continue
                fi

                if [ ! -f "$summary_file" ]; then
                    log_warn "[$title] Processing finished but no summary found"
                    failed=$((failed + 1))
                    continue
                fi
            fi

            # Case 2: has summary but hook hasn't run → run hook
            if [ -f "$summary_file" ] && [ ! -f "$hook_done_file" ] && [ -n "$POST_SUMMARY_HOOK" ]; then
                log_info "[$title] Running post-summary hook..."

                if [ "$dry_run" = true ]; then
                    hooked=$((hooked + 1))
                    continue
                fi

                if run_post_summary_hook "$summary_file"; then
                    # Write marker so we don't re-run on next catchup
                    touch "$hook_done_file"
                    hooked=$((hooked + 1))
                else
                    log_warn "[$title] Hook failed"
                    failed=$((failed + 1))
                fi
            fi
        done
    done

    echo ""
    if [ "$dry_run" = true ]; then
        log_info "Dry run — would process: $processed, run hook: $hooked"
    else
        log_success "Catchup complete — processed: $processed, hook ran: $hooked, failed: $failed"
    fi
}

status_recordings() {
    if [ ! -d "$OUTPUT_DIR" ] || [ -z "$(ls -A "$OUTPUT_DIR" 2>/dev/null)" ]; then
        log_warn "No recordings found in $OUTPUT_DIR"
        exit 0
    fi

    local col_date=12
    local col_title=32
    local col_status=28
    local col_dur=6

    # Header
    printf "%-${col_date}s  %-${col_title}s  %-${col_status}s  %s\n" \
        "DATE" "TITLE" "STATUS" "DUR"
    printf "%-${col_date}s  %-${col_title}s  %-${col_status}s  %s\n" \
        "------------" "--------------------------------" "----------------------------" "------"

    local total=0 pending=0 partial=0 done_local=0 done_uploaded=0

    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        [ -d "$date_dir" ] || continue

        local date_name
        date_name=$(basename "$date_dir")
        local formatted_date="${date_name:0:4}-${date_name:4:2}-${date_name:6:2}"

        for meeting_dir in "$date_dir"/meeting_*; do
            [ -d "$meeting_dir" ] || continue

            local base_name
            base_name=$(basename "$meeting_dir")
            local base="${meeting_dir}/${base_name}"

            # Locate audio (wav preferred, then mp3)
            local wav_file="${base}.wav"
            local mp3_file="${base}.mp3"
            local txt_file="${base}.txt"
            local summary_file="${base}_summary.md"
            local metadata_file="${base}_metadata.json"
            local hook_done_file="${base}.hook_done"

            local has_wav=false has_mp3=false has_txt=false has_summary=false has_hook_done=false
            [ -f "$wav_file" ]       && has_wav=true
            [ -f "$mp3_file" ]       && has_mp3=true
            [ -f "$txt_file" ]       && has_txt=true
            [ -f "$summary_file" ]   && has_summary=true
            [ -f "$hook_done_file" ] && has_hook_done=true

            # Dual-track recordings (AUDIO_SOURCE_TYPE=dual) store audio as a
            # voice/system pair, never as the mixed ${base}.wav, so a pending dual
            # meeting would otherwise be invisible in status. Recognise the pair
            # (raw WAVs while pending, MP3s once compressed after processing).
            local has_dual=false dual_audio=""
            if [ -f "${base}.voice.wav" ] && [ -f "${base}.system.wav" ]; then
                has_dual=true; dual_audio="${base}.voice.wav"
            elif [ -f "${base}.voice.mp3" ] && [ -f "${base}.system.mp3" ]; then
                has_dual=true; dual_audio="${base}.voice.mp3"
            fi

            # Skip dirs with no recognisable audio at all and no txt either
            if ! $has_wav && ! $has_mp3 && ! $has_txt && ! $has_dual; then
                continue
            fi

            total=$((total + 1))

            # Determine status
            local status_text status_color
            if $has_summary && $has_hook_done; then
                status_text="done + hook ran"
                status_color="$GREEN"
                done_uploaded=$((done_uploaded + 1))
            elif $has_summary; then
                if [ -n "$POST_SUMMARY_HOOK" ]; then
                    status_text="done, hook pending"
                else
                    status_text="done"
                fi
                status_color="$GREEN"
                done_local=$((done_local + 1))
            elif $has_txt; then
                status_text="transcribed, no summary"
                status_color="$YELLOW"
                partial=$((partial + 1))
            elif $has_wav || $has_mp3 || $has_dual; then
                status_text="recorded, not processed"
                status_color="$YELLOW"
                pending=$((pending + 1))
            else
                status_text="unknown"
                status_color="$NC"
            fi

            # Title from metadata
            local title=""
            if [ -f "$metadata_file" ]; then
                title=$(python3 -c "
import json, sys
try:
    d = json.load(open('$metadata_file'))
    print(d.get('title',''))
except Exception:
    pass
" 2>/dev/null)
            fi
            [ -z "$title" ] && title="$base_name"

            # Duration from wav/mp3 via ffprobe if available
            local duration=""
            local audio_for_dur=""
            $has_wav && audio_for_dur="$wav_file"
            $has_mp3 && audio_for_dur="$mp3_file"
            [ -z "$audio_for_dur" ] && $has_dual && audio_for_dur="$dual_audio"
            if [ -n "$audio_for_dur" ] && command -v ffprobe &>/dev/null; then
                local secs
                secs=$(ffprobe -v error -show_entries format=duration \
                    -of default=noprint_wrappers=1:nokey=1 "$audio_for_dur" 2>/dev/null | cut -d. -f1)
                if [ -n "$secs" ] && [ "$secs" -gt 0 ] 2>/dev/null; then
                    duration=$(printf "%dm" "$((secs / 60))")
                fi
            fi

            # Truncate title for display
            local display_title="${title:0:$col_title}"

            printf "%-${col_date}s  %-${col_title}s  ${status_color}%-${col_status}s${NC}  %s\n" \
                "$formatted_date" "$display_title" "$status_text" "${duration:--}"
        done
    done

    echo ""
    echo "Total: $total  |  Pending: $pending  |  Partial: $partial  |  Done (local): $done_local  |  Done (uploaded): $done_uploaded"
}

# --------------------------------------------------------------------------- #
# Guided terminal flow (issue #5): record -> review -> confirm -> publish.
#
# Plain line-based prompts (read from /dev/tty, like record_audio.sh) so it works
# over a bare SSH session and when stdout is a pipe — NOT a curses/ncurses TUI.
# Recording, transcription and summarization reuse the existing record_meeting()
# and `process` subcommand; this only adds orchestration, display and the confirm
# gate. Publishing is confirm-gated PER TARGET and never automatic: the internal
# `process` run is invoked with the automatic POST_SUMMARY_HOOK suppressed, and a
# publisher runs only on an explicit per-target yes (empty/EOF answer -> NO).
# --------------------------------------------------------------------------- #

# Read one line from the controlling terminal. Echoes the entered text to stdout
# (so command substitution captures the answer, while the prompt goes to the tty);
# echoes nothing on EOF or when no terminal is available (piped / no tty), so
# callers fail safe. Robust under `set -e`: the /dev/tty redirection is wrapped in
# a group whose stderr is pre-silenced, so a failed open degrades to empty instead
# of aborting the script.
_ui_prompt() {
    local __prompt="$1"
    local __ans=""
    { printf '%s' "$__prompt" >/dev/tty; } 2>/dev/null || return 0
    { IFS= read -r __ans </dev/tty; }   2>/dev/null || return 0
    printf '%s' "$__ans"
}

# Show a review file: page with less when interactive on a TTY, otherwise plain
# cat (pipe / SSH without a tty / non-interactive). $1 = file to display.
_ui_show_file() {
    local __file="$1"
    if [ -t 1 ] && command -v less >/dev/null 2>&1; then
        less -R "$__file" </dev/tty || cat "$__file"
    else
        cat "$__file"
    fi
}

meeting_ui() {
    local duration=""
    local title=""
    local cli_speakers=""
    local process_opts=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--title)       title="$2"; shift 2 ;;
            -d|--duration)    duration="$2"; shift 2 ;;
            -m|--model)       process_opts+=(-m "$2"); shift 2 ;;
            -l|--language)    process_opts+=(-l "$2"); shift 2 ;;
            -o|--ollama)      process_opts+=(-o "$2"); shift 2 ;;
            --initial-prompt) process_opts+=(--initial-prompt "$2"); shift 2 ;;
            --hotwords)       process_opts+=(--hotwords "$2"); shift 2 ;;
            --diarize)        process_opts+=(--diarize); shift ;;
            -s|--speakers)    process_opts+=(-s "$2"); cli_speakers="$2"; shift 2 ;;
            -h|--help)
                echo "Usage: $0 meeting [OPTIONS]"
                echo ""
                echo "Guided flow: record -> review -> edit title -> confirm -> publish."
                echo "Publishing is confirm-gated per target and never automatic. Works"
                echo "over SSH / a plain terminal (line prompts, no TUI)."
                echo ""
                echo "Options:"
                echo "  -t, --title TITLE     Meeting title (prompted during recording if omitted)"
                echo "  -d, --duration SEC    Auto-stop after SEC seconds (default: stop with Ctrl+C)"
                echo "  -m, --model MODEL     Whisper model (tiny|base|small|medium|large-v3)"
                echo "  -l, --language LANG   Language code (uk|ru|en|auto, default: auto-detect)"
                echo "  -o, --ollama MODEL    Ollama model for summarization (default: ${OLLAMA_MODEL})"
                echo "  --cloud               Summarize/transcribe via the cloud this run (off by default)"
                echo "  --initial-prompt TEXT Decoding-bias sentence (overrides --hotwords)"
                echo "  --hotwords TERMS      Space-separated tech terms to bias transcription"
                echo "  --diarize             Enable speaker diarization"
                echo "  --no-diarize          Skip diarization this run (overrides config)"
                echo "  -s, --speakers NUM    Number of speakers (requires --diarize)"
                echo ""
                echo "AUDIO_SOURCE_TYPE (env) selects capture mode (microphone|monitor|both|dual)."
                return 0
                ;;
            *) shift ;;
        esac
    done

    log_info "Guided meeting: record -> review -> confirm -> publish"
    log_info "Publishing is confirm-gated; nothing is sent automatically."
    echo ""

    # Fail fast if the transcription environment is missing, BEFORE recording, so
    # we never capture a full meeting only to die at the transcribe step.
    check_python_env

    # Cloud confirm: make the off-machine upload explicit before we record.
    # Declining falls back to fully local processing for this run. A blank/EOF
    # answer (SSH/pipe) keeps cloud on, since the user opted in explicitly.
    if _is_true "$CLOUD"; then
        cloud_banner
        local _cloud_ans
        _cloud_ans=$(_ui_prompt "Continue in cloud mode (data leaves this machine)? [Y/n]: ")
        case "$(printf '%s' "$_cloud_ans" | tr '[:upper:]' '[:lower:]')" in
            n|no)
                CLOUD="false"
                cloud_resolve
                log_info "Cloud mode disabled for this run — processing locally."
                ;;
        esac
        echo ""
    fi

    # Step 1: Record (reuses record_meeting; Ctrl+C or -d stops recording).
    log_info "Step 1/4: Recording (press Ctrl+C to stop)..."
    local recording_result_file="/tmp/shepitnote_meeting_$$"
    local record_args=()
    [ -n "$duration" ] && record_args+=(-d "$duration")
    [ -n "$title" ] && record_args+=(-t "$title")

    # Suppress record_audio.sh's interactive title prompt: this guided flow sets
    # the title in its own step (3b) after showing the summary, so a second prompt
    # here would be redundant and would block before transcription.
    local rec_exit=0
    SHEPITNOTE_SKIP_TITLE_PROMPT=1 record_meeting "${record_args[@]}" > "$recording_result_file" || rec_exit=$?
    log_debug "Recording exit code: $rec_exit"

    local audio_file=""
    if [ -f "$recording_result_file" ]; then
        audio_file=$(cat "$recording_result_file")
        rm -f "$recording_result_file"
    fi

    if [ -z "$audio_file" ] || [ ! -f "$audio_file" ]; then
        log_error "Recording failed or produced no audio file"
        return 1
    fi
    echo ""

    # Resolve the meeting base (handles the dual-track voice/system pair, which
    # detect_dual_tracks reduces to the shared base; single track just strips .wav).
    local base
    base=$(detect_dual_tracks "$audio_file")
    [ -z "$base" ] && base="${audio_file%.*}"
    local base_dir base_name
    base_dir=$(dirname "$base")
    base_name=$(basename "$base")
    local summary_file="${base}_summary.md"
    local metadata_file="${base}_metadata.json"
    local hook_done_file="${base}.hook_done"

    # Step 1b: for dual-track meetings with Remote diarization enabled, ask how
    # many people were on the far side so pyannote targets that exact count rather
    # than auto-detecting — which over-splits on compressed VoIP audio (a real
    # 6-person call was detected as 8). Sets DUAL_REMOTE_SPEAKERS, which the dual
    # processing path forwards to diarize.py as -s. Skipped when the count is
    # already in the environment, was passed with -s, or this isn't a dual
    # recording. A blank/EOF answer falls back to auto-detect (SSH/pipe-safe).
    if [ "${DUAL_REMOTE_DIARIZATION:-false}" = "true" ] \
       && [ -f "${base}.voice.wav" ] && [ -f "${base}.system.wav" ] \
       && [ -z "${DUAL_REMOTE_SPEAKERS:-}" ]; then
        local _spk="$cli_speakers"
        [ -z "$_spk" ] && _spk=$(_ui_prompt "How many people were on the call, not counting you? (blank = auto-detect): ")
        if [[ "$_spk" =~ ^[1-9][0-9]*$ ]]; then
            export DUAL_REMOTE_SPEAKERS="$_spk"
            log_info "Diarization will target $_spk remote speaker(s)."
        else
            log_info "Auto-detecting the number of remote speakers."
        fi
        echo ""
    fi

    # Step 2: Transcribe + summarize via the EXISTING `process` subcommand, with
    # the automatic post-summary hook SUPPRESSED so nothing publishes here. process
    # auto-detects dual-track recordings, so this covers them too. Output is teed to
    # a log so the detected language can be recovered for the review header even for
    # single-track runs (which persist a .txt transcript but no language JSON); the
    # interactive --diarize label prompt is unaffected because label.py reads
    # /dev/tty, not this pipe.
    log_info "Step 2/4: Transcribing and summarizing (auto-publish suppressed)..."
    echo ""
    local proc_log="/tmp/shepitnote_meeting_proc_$$.log"
    local proc_exit=0
    set +e
    HUSHNOTE_SKIP_POST_SUMMARY_HOOK=1 "$0" process "$audio_file" "${process_opts[@]}" 2>&1 | tee "$proc_log"
    proc_exit=${PIPESTATUS[0]}
    set -e
    if [ "$proc_exit" -ne 0 ]; then
        log_error "Processing failed (exit $proc_exit). Not publishing."
        rm -f "$proc_log"
        return 1
    fi
    if [ ! -f "$summary_file" ]; then
        log_error "Summary not found after processing: $summary_file"
        log_error "Summarization may have failed — not publishing."
        rm -f "$proc_log"
        return 1
    fi
    echo ""

    # Step 3: Review — detected language + transcript + summary. Prefer the sibling
    # transcription JSON (present for dual tracks); fall back to the 'Detected
    # language:' line captured from the process log (single-track path).
    local language
    language=$(python3 "${SCRIPT_DIR}/meeting_ui.py" language "$base_dir" "$base_name" 2>/dev/null || echo "unknown")
    if { [ "$language" = "unknown" ] || [ -z "$language" ]; } && [ -f "$proc_log" ]; then
        local from_log
        from_log=$(grep -a 'Detected language:' "$proc_log" 2>/dev/null | head -1 \
            | sed -n 's/.*Detected language:[[:space:]]*\([A-Za-z][A-Za-z-]*\).*/\1/p') || from_log=""
        [ -n "$from_log" ] && language="$from_log"
    fi
    [ -z "$language" ] && language="unknown"
    rm -f "$proc_log"

    local transcript_file="" cand
    for cand in "${base}.txt" "${base}_trimmed.txt"; do
        if [ -f "$cand" ]; then transcript_file="$cand"; break; fi
    done

    local review_file="/tmp/shepitnote_review_$$"
    {
        echo "======================================================================"
        echo " MEETING REVIEW"
        echo "======================================================================"
        echo "Detected language:  ${language}"
        echo "Meeting:            ${base_name}"
        echo "Summary file:       ${summary_file}"
        echo ""
        echo "----------------------------------------------------------------------"
        echo " TRANSCRIPT"
        echo "----------------------------------------------------------------------"
        if [ -n "$transcript_file" ]; then
            cat "$transcript_file"
        else
            echo "(transcript file not found)"
        fi
        echo ""
        echo "----------------------------------------------------------------------"
        echo " SUMMARY"
        echo "----------------------------------------------------------------------"
        cat "$summary_file"
        echo ""
    } > "$review_file"

    log_info "Step 3/4: Review the meeting below (detected language: ${language})."
    _ui_show_file "$review_file"
    rm -f "$review_file"
    echo ""

    # Step 3b: Edit the meeting title, written into <base>_metadata.json so the
    # publishers use the new value.
    local current_title
    current_title=$(python3 "${SCRIPT_DIR}/meeting_ui.py" get-title "$metadata_file" 2>/dev/null || echo "")
    log_info "Current title: ${current_title:-(none)}"
    local new_title
    new_title=$(_ui_prompt "New title (blank = keep current): ")
    if [ -n "$new_title" ]; then
        if python3 "${SCRIPT_DIR}/meeting_ui.py" set-title "$metadata_file" "$new_title" >/dev/null; then
            log_success "Title updated to: $new_title"
        else
            log_warn "Could not update title in metadata; keeping: ${current_title:-(none)}"
        fi
    fi
    echo ""

    # Step 4: Confirm-gated publishing, per configured target. A default / blank /
    # EOF answer is treated as NO by meeting_ui.py confirm (fail safe).
    log_info "Step 4/4: Publishing (explicit confirmation required per target)."
    local targets=() line
    while IFS= read -r line; do
        [ -n "$line" ] && targets+=("$line")
    done < <(python3 "${SCRIPT_DIR}/meeting_ui.py" targets 2>/dev/null)

    if [ ${#targets[@]} -eq 0 ]; then
        log_info "No publish target configured (set CONFLUENCE_BASE_URL and/or"
        log_info "SLACK_WEBHOOK_URL / SLACK_BOT_TOKEN in .shepitnoterc). Skipping publish."
        echo ""
        log_success "Guided meeting complete. Summary: $summary_file"
        return 0
    fi

    # Targets are ordered confluence-then-slack (enabled_publishers), so Confluence
    # is decided before Slack. This per-target loop invokes the publishers directly
    # rather than via hooks/publish.py, so we reproduce that dispatcher's deferral
    # gate inline: when Confluence was CONFIRMED but its publish did not yield a
    # page id (it failed and no <base>.confluence_page_id marker exists), we skip
    # Slack. Otherwise slack_publish.py would post a linkless message and latch
    # <base>.slack_done, permanently dropping the Confluence link (issue #4's
    # invariant). A DECLINED Confluence is different — the user asked for a
    # Slack-only post — so it is not gated (confluence_confirmed stays false).
    local target ans publisher rc
    local confluence_confirmed=false confluence_rc=1
    local confluence_marker="${base}.confluence_page_id"
    for target in "${targets[@]}"; do
        if [ "$target" = "slack" ] && [ "$confluence_confirmed" = true ] \
           && [ "$confluence_rc" -ne 0 ] && [ ! -f "$confluence_marker" ]; then
            log_warn "Skipping Slack: Confluence was confirmed but its publish failed and no"
            log_warn "page link is available. Posting to Slack now would drop the Confluence"
            log_warn "link permanently (the Slack post is one-shot). After Confluence recovers,"
            log_warn "re-run the publishers directly to link them:"
            log_warn "  ${SCRIPT_DIR}/hooks/confluence_publish.py \"$summary_file\""
            log_warn "  ${SCRIPT_DIR}/hooks/slack_publish.py \"$summary_file\""
            continue
        fi
        ans=$(_ui_prompt "Publish to ${target}? [y/N]: ")
        if python3 "${SCRIPT_DIR}/meeting_ui.py" confirm "$ans"; then
            case "$target" in
                confluence) publisher="${SCRIPT_DIR}/hooks/confluence_publish.py" ;;
                slack)      publisher="${SCRIPT_DIR}/hooks/slack_publish.py" ;;
                *)          log_warn "Unknown publish target: $target"; continue ;;
            esac
            log_info "Publishing to ${target}..."
            rc=0
            "$publisher" "$summary_file" || rc=$?
            [ "$target" = "confluence" ] && { confluence_confirmed=true; confluence_rc=$rc; }
            if [ "$rc" -eq 0 ]; then
                log_success "Published to ${target}."
            else
                log_error "Publishing to ${target} failed (exit $rc)."
            fi
        else
            log_info "Skipped ${target} (not confirmed)."
        fi
    done

    # Mark the meeting as handled by the guided flow. The internal `process` run
    # suppressed the auto-hook and left no .hook_done marker, so without this a
    # later `shepitnote catchup` would treat the meeting as pending and auto-publish
    # to EVERY configured target with no confirmation — overriding the per-target
    # choices just made here (including an explicit "no"). Writing .hook_done tells
    # catchup this meeting's publish decision is already settled. To (re)publish a
    # target later, invoke its hook under hooks/ directly.
    touch "$hook_done_file" 2>/dev/null || true

    echo ""
    log_success "Guided meeting complete. Summary: $summary_file"
}

# Main command dispatcher
main() {
    # Global --cloud / --no-cloud flag: opt in/out of cloud processing for this
    # run. Off by default. Strip it wherever it appears (before or after the
    # command) so per-command parsers never see it, then re-resolve the cloud
    # settings with the new value.
    local _args=() _a _cloud_flag="" _nodiarize="" _summary_flag=""
    for _a in "$@"; do
        case "$_a" in
            --cloud)          _cloud_flag="true" ;;
            --no-cloud)       _cloud_flag="false" ;;
            --no-diarize)     _nodiarize="1" ;;
            --local-summary)  _summary_flag="false" ;;   # summarize locally even in cloud mode
            --cloud-summary)  _summary_flag="true"  ;;   # force cloud summary
            *)                _args+=("$_a") ;;
        esac
    done
    if [ ${#_args[@]} -gt 0 ]; then set -- "${_args[@]}"; else set --; fi
    # Apply the per-run cloud overrides, then re-resolve once. The summary flag
    # sets the same explicit override CLOUD_SUMMARIZE=... would, so it composes
    # with --cloud (cloud transcribe + local summary in one run).
    [ -n "$_summary_flag" ] && CLOUD_SUMMARIZE_EXPLICIT="$_summary_flag"
    [ -n "$_cloud_flag" ]   && CLOUD="$_cloud_flag"
    if [ -n "$_cloud_flag" ] || [ -n "$_summary_flag" ]; then
        cloud_resolve
    fi
    # Skip speaker diarization for this run. Export the sentinel so process-last's
    # re-invoked child (which re-sources .shepitnoterc) honors it too.
    if [ -n "$_nodiarize" ]; then
        DUAL_REMOTE_DIARIZATION=false
        export DUAL_REMOTE_DIARIZATION SHEPITNOTE_DIARIZE_OVERRIDE=false
    fi

    if [ $# -eq 0 ]; then
        print_usage
        exit 0
    fi

    check_dependencies

    local command="$1"
    shift

    # Commands that transcribe need the Python worker env; verify it up front so
    # they fail with a clear, actionable message instead of a cryptic
    # missing-binary error mid-run. (full/meeting check it before recording.)
    case "$command" in
        transcribe|process|process-last|process-meeting)
            check_python_env
            ;;
    esac

    # Warn once, up front, when cloud mode will send data off the machine. The
    # guided `meeting` flow prints its own banner + confirm inside meeting_ui.
    case "$command" in
        transcribe|process|process-last|process-meeting|full|catchup)
            cloud_banner
            ;;
    esac

    case "$command" in
        record)
            # Capture the path via a temp file (not $(...)) to preserve the
            # Ctrl+C-to-stop behavior, then point the user at the next step so a
            # record-only run doesn't look like it stalled.
            local rec_result_file="/tmp/shepitnote_reccmd_$$"
            local rec_rc=0
            record_meeting "$@" > "$rec_result_file" || rec_rc=$?
            local rec_path=""
            if [ -f "$rec_result_file" ]; then
                rec_path=$(cat "$rec_result_file"); rm -f "$rec_result_file"
            fi
            [ -n "$rec_path" ] && echo "$rec_path"
            if [ -n "$rec_path" ] && [ -f "$rec_path" ]; then
                echo "" >&2
                log_info "Record-only: transcription/summary do NOT run automatically."
                log_info "To transcribe + summarize this recording, run:"
                log_info "  ./shepitnote process-last"
            fi
            ;;
        aec)
            aec_command "$@"
            ;;
        transcribe)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 transcribe FILE [OPTIONS]"
                exit 1
            fi
            transcribe_meeting "$@"
            ;;
        summarize)
            if [ $# -eq 0 ]; then
                log_error "Missing transcription file argument"
                echo "Usage: $0 summarize FILE [OPTIONS]"
                exit 1
            fi
            summarize_meeting "$@"
            ;;
        diarize)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 diarize FILE [OPTIONS]"
                exit 1
            fi
            diarize_meeting "$@"
            ;;
        label)
            if [ $# -eq 0 ]; then
                log_error "Missing diarized file argument"
                echo "Usage: $0 label FILE"
                exit 1
            fi
            label_speakers "$@"
            ;;
        apply-labels)
            if [ $# -eq 0 ]; then
                log_error "Missing labeled file argument"
                echo "Usage: $0 apply-labels FILE [OPTIONS]"
                exit 1
            fi
            apply_speaker_labels "$@"
            ;;
        trim)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 trim FILE [--noise -30] [--min-silence 60]"
                echo ""
                echo "Detect and remove silent tail from an audio file"
                exit 1
            fi
            trim_audio "$@"
            ;;
        compress)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 compress FILE"
                echo ""
                echo "Compress WAV to MP3 and delete WAV (default workflow behavior)"
                exit 1
            fi
            compress_audio "$1" --delete-wav
            ;;
        clean)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 clean FILE"
                echo ""
                echo "Delete ALL audio files (WAV and MP3), keep only text/transcripts"
                exit 1
            fi
            clean_audio "$@"
            ;;
        process)
            if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
                echo "Usage: $0 process FILE [OPTIONS]"
                echo ""
                echo "Process an existing recording (transcribe + optional diarize + summarize)"
                echo ""
                echo "Options:"
                echo "  -m, --model MODEL     Whisper model (tiny|base|small|medium|large-v3, default: large-v3)"
                echo "  -l, --language LANG   Language code (uk|ru|en|auto, default: auto-detect)"
                echo "  --initial-prompt TEXT Decoding-bias sentence for tech-term spelling (overrides --hotwords)"
                echo "  --hotwords TERMS      Space-separated tech terms to bias transcription spelling"
                echo "  -o, --ollama MODEL    Ollama model for summarization"
                echo "  -s, --speakers NUM    Number of speakers (requires --diarize)"
                echo "  --diarize             Enable speaker diarization"
                echo "  --timeout SECS        Kill processing after SECS seconds (default: ${PROCESS_TIMEOUT})"
                echo ""
                echo "Examples:"
                echo "  # Simple processing (transcribe + summarize)"
                echo "  $0 process recordings/meeting.wav -m tiny"
                echo ""
                echo "  # With speaker diarization"
                echo "  $0 process recordings/meeting.wav --diarize --speakers 2 -m small"
                exit 0
            fi

            local audio_file="$1"
            shift

            if [ ! -f "$audio_file" ]; then
                log_error "Audio file not found: $audio_file"
                exit 1
            fi

            # Parse arguments
            local whisper_model="$WHISPER_MODEL"
            local whisper_language="$WHISPER_LANGUAGE"
            local whisper_initial_prompt="$WHISPER_INITIAL_PROMPT"
            local whisper_hotwords="$WHISPER_HOTWORDS"
            local ollama_model="$OLLAMA_MODEL"
            local enable_diarization=false
            local num_speakers=""
            local enable_compression=true
            local keep_wav=false
            local clean_all=false
            local process_timeout="$PROCESS_TIMEOUT"
            local enable_trim=true
            local keep_untrimmed=false
            local keep_trimmed=true

            while [[ $# -gt 0 ]]; do
                case $1 in
                    -m|--model)
                        whisper_model="$2"
                        shift 2
                        ;;
                    -l|--language)
                        whisper_language="$2"
                        shift 2
                        ;;
                    --initial-prompt)
                        whisper_initial_prompt="$2"
                        shift 2
                        ;;
                    --hotwords)
                        whisper_hotwords="$2"
                        shift 2
                        ;;
                    -o|--ollama)
                        ollama_model="$2"
                        shift 2
                        ;;
                    --diarize)
                        enable_diarization=true
                        shift
                        ;;
                    -s|--speakers)
                        num_speakers="$2"
                        shift 2
                        ;;
                    --no-compress)
                        enable_compression=false
                        shift
                        ;;
                    --keep-wav)
                        keep_wav=true
                        shift
                        ;;
                    --no-trim)
                        enable_trim=false
                        shift
                        ;;
                    --keep-untrimmed)
                        keep_untrimmed=true
                        shift
                        ;;
                    --keep-trimmed)
                        keep_trimmed=true
                        shift
                        ;;
                    --clean)
                        clean_all=true
                        shift
                        ;;
                    --timeout)
                        process_timeout="$2"
                        shift 2
                        ;;
                    *)
                        shift
                        ;;
                esac
            done

            local timeout_human
            if [ "$process_timeout" -ge 3600 ] 2>/dev/null; then
                timeout_human="$((process_timeout / 3600))h$(( (process_timeout % 3600) / 60 ))m"
            else
                timeout_human="${process_timeout}s"
            fi
            log_info "Timeout: ${timeout_human} (override with --timeout SECS or PROCESS_TIMEOUT env var)"

            # Run the entire processing block under a timeout.
            # The subshell runs as a background job; a watchdog kills the process group
            # with SIGTERM after process_timeout seconds, then SIGKILL after 30 more.
            (
            # Dual-track recording? Process the You/Remote pair without
            # diarization. Runs inside the subshell so the timeout still applies.
            local dual_base
            dual_base=$(detect_dual_tracks "$audio_file")
            if [ -n "$dual_base" ]; then
                local dual_args=(-m "$whisper_model")
                [ -n "$whisper_language" ] && dual_args+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && dual_args+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && dual_args+=(--hotwords "$whisper_hotwords")
                [ -n "$ollama_model" ] && dual_args+=(-o "$ollama_model")
                [ "$enable_compression" = false ] && dual_args+=(--no-compress)
                [ "$keep_wav" = true ] && dual_args+=(--keep-wav)
                [ "$clean_all" = true ] && dual_args+=(--clean)
                process_dual_meeting "$dual_base" "${dual_args[@]}"
            elif [ "$enable_diarization" = true ]; then
                log_info "Processing recording with diarization: $audio_file"
                echo ""

                # Six fixed steps plus a final compress/clean step unless both
                # compression and --clean are off.
                local _pdiar_total=6
                { [ "$clean_all" = true ] || [ "$enable_compression" = true ]; } && _pdiar_total=$((_pdiar_total + 1))
                steps_init "$_pdiar_total"

                # Step: Diarize
                step "Identifying speakers"
                local speakers_file
                if [ -n "$num_speakers" ]; then
                    speakers_file=$(diarize_meeting "$audio_file" -s "$num_speakers")
                else
                    speakers_file=$(diarize_meeting "$audio_file")
                fi

                if [ -z "$speakers_file" ] || [ ! -f "$speakers_file" ]; then
                    log_error "Diarization failed"
                    exit 1
                fi
                step_done
                echo ""

                # Step: Transcribe
                step "Transcribing audio"
                local base="${audio_file%.*}"
                local transcription_json="${base}.json"

                local transcribe_cmd=("${NICE[@]}" "$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$audio_file" -m "$whisper_model" -f json -o "$transcription_json")
                [ -n "$whisper_language" ] && transcribe_cmd+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && transcribe_cmd+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && transcribe_cmd+=(--hotwords "$whisper_hotwords")
                "${transcribe_cmd[@]}"

                if [ ! -f "$transcription_json" ]; then
                    log_error "Transcription failed"
                    exit 1
                fi
                step_done
                echo ""

                # Step: Merge
                step "Merging speaker info with transcription"
                local diarized_file="${base}_diarized.json"

                "$PYTHON" "${SCRIPT_DIR}/merge_diarization.py" "$speakers_file" "$transcription_json" -o "$diarized_file"

                if [ ! -f "$diarized_file" ]; then
                    log_error "Merge failed"
                    exit 1
                fi
                step_done
                echo ""

                # Step: Label speakers
                step "Label speakers with their names"
                echo ""

                # Call label_speakers without command substitution to allow interactive input
                label_speakers "$diarized_file"

                # Determine output file manually
                local base="${diarized_file%_diarized.json}"
                local labeled_file="${base}_speakers_labeled.json"

                if [ ! -f "$labeled_file" ]; then
                    log_error "Labeling failed"
                    exit 1
                fi
                step_done
                echo ""

                # Step: Apply labels
                step "Creating final transcript with speaker names"
                local transcription_file=$(apply_speaker_labels "$labeled_file" -f txt)

                if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
                    log_error "Apply labels failed"
                    exit 1
                fi
                step_done
                echo ""

                # Step: Summarize
                step "Generating summary"
                local summary_file
                local summarize_args=()
                [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
                [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
                summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

                if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
                    log_error "Summarization failed"
                    exit 1
                fi
                step_done

                echo ""

                # Step: Compress audio and cleanup
                if [ "$clean_all" = true ]; then
                    step "Removing all audio files"
                    [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
                    local mp3_file="${audio_file%.wav}.mp3"
                    [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
                    audio_file="(deleted)"
                    step_done
                    echo ""
                elif [ "$enable_compression" = true ]; then
                    step "Compressing audio to MP3"
                    local mp3_file
                    if [ "$keep_wav" = true ]; then
                        mp3_file=$(compress_audio "$audio_file")
                    else
                        mp3_file=$(compress_audio "$audio_file" --delete-wav)
                    fi

                    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                        audio_file="$mp3_file"
                    fi
                    step_done
                    echo ""
                fi

                steps_total_done
                log_success "Processing complete with diarization!"
                echo ""
                echo "Files generated:"
                echo "  Audio:          $audio_file"
                echo "  Diarization:    $speakers_file"
                echo "  Labeled:        $labeled_file"
                echo "  Transcription:  $transcription_file"
                echo "  Summary:        $summary_file"
            else
                # Simple transcribe + summarize workflow
                log_info "Processing recording: $audio_file"
                echo ""

                # Two fixed steps (transcribe, summarize) plus optional compress
                # and trim steps.
                local _simple_total=2
                { [ "$clean_all" = false ] && [ "$enable_compression" = true ]; } && _simple_total=$((_simple_total + 1))
                [ "$enable_trim" = true ] && _simple_total=$((_simple_total + 1))
                steps_init "$_simple_total"

                local mp3_file=""
                local transcribe_source="$audio_file"

                # Step: Compress WAV → MP3, delete WAV
                if [ "$clean_all" = true ]; then
                    : # skip compression, delete everything at end
                elif [ "$enable_compression" = true ]; then
                    step "Compressing audio to MP3"
                    if [ "$keep_wav" = true ]; then
                        mp3_file=$(compress_audio "$audio_file")
                    else
                        mp3_file=$(compress_audio "$audio_file" --delete-wav)
                    fi
                    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                        transcribe_source="$mp3_file"
                    fi
                    step_done
                    echo ""
                fi

                # Step: Trim silent tail
                local trimmed_file=""
                if [ "$enable_trim" = true ] && [ -f "$transcribe_source" ]; then
                    step "Trimming silent tail"
                    trimmed_file=$(trim_audio "$transcribe_source")
                    if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                        transcribe_source="$trimmed_file"
                    fi
                    step_done
                    echo ""
                fi

                # Step: Transcribe
                step "Transcribing audio"
                local process_transcribe_args=(-m "$whisper_model")
                [ -n "$whisper_language" ] && process_transcribe_args+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && process_transcribe_args+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && process_transcribe_args+=(--hotwords "$whisper_hotwords")
                local transcription_file
                transcription_file=$(transcribe_meeting "$transcribe_source" "${process_transcribe_args[@]}")
                step_done

                if [ -f "$transcription_file" ]; then
                    echo ""

                    # Step: Summarize
                    step "Generating summary"
                    local summary_file
                    local summarize_args=()
                    [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
                    [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
                    summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")
                    step_done

                    echo ""

                    # Cleanup audio
                    if [ "$clean_all" = true ]; then
                        log_info "Removing all audio files..."
                        [ -f "$audio_file" ]    && rm "$audio_file"    && log_success "Deleted: $audio_file"
                        [ -n "$mp3_file" ] && [ -f "$mp3_file" ]       && rm "$mp3_file" && log_success "Deleted: $mp3_file"
                        [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && rm "$trimmed_file" && log_success "Deleted: $trimmed_file"
                        audio_file="(deleted)"
                    else
                        if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                            if [ "$keep_untrimmed" = false ]; then
                                rm "$mp3_file" && log_info "Deleted untrimmed: $mp3_file"
                            fi
                        fi
                        if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ "$keep_trimmed" = false ]; then
                            rm "$trimmed_file" && log_info "Deleted trimmed audio: $trimmed_file"
                        fi
                    fi

                    echo ""
                    steps_total_done
                    log_success "Processing complete!"
                    echo ""
                    echo "Files generated:"
                    [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && echo "  Audio (trimmed):  $trimmed_file"
                    [ -n "$mp3_file" ]     && [ -f "$mp3_file" ]     && echo "  Audio (full):     $mp3_file"
                    echo "  Transcription:    $transcription_file"
                    echo "  Summary:          $summary_file"

                    run_post_summary_hook "$summary_file" && \
                        touch "${summary_file%_summary.md}.hook_done" || true
                fi
            fi
            ) &
            local _proc_pid=$!

            # Watchdog: sleep in the background, then kill the processing subshell
            # if it is still alive after the timeout. Its stdout/stderr go to
            # /dev/null on purpose: in the guided `meeting` flow the whole `process`
            # run is piped to `tee`, so this subshell (and the `sleep` it spawns)
            # would otherwise inherit that pipe's write-end. After a NORMAL run the
            # watchdog is still mid-sleep when we kill it; a `sleep` orphaned that
            # way would keep the pipe open and hang the guided flow forever even
            # though processing succeeded. Sending its fds to /dev/null makes that
            # impossible. The timeout itself is reported by the parent below (the
            # 143/137 exit check), so nothing is lost by muting the watchdog.
            (
                sleep "$process_timeout"
                if kill -0 "$_proc_pid" 2>/dev/null; then
                    kill -TERM "$_proc_pid" 2>/dev/null
                    sleep 30
                    kill -KILL "$_proc_pid" 2>/dev/null
                fi
            ) >/dev/null 2>&1 &
            local _watchdog_pid=$!

            # Capture the processing exit status without tripping `set -e`: a
            # failed `wait` (e.g. the subshell was killed by the watchdog) would
            # otherwise abort here before we can inspect the code. `|| _exit=$?`
            # keeps the failing wait out of set -e's reach.
            local _exit=0
            wait "$_proc_pid" || _exit=$?

            # Stop the watchdog now that processing is done. Kill its `sleep` child
            # FIRST, while the parent link is still intact, so no orphaned sleep is
            # left lingering for the rest of the (up to 2h) timeout window; then the
            # subshell itself. All guarded with `|| true` because after a normal run
            # the watchdog is still sleeping, so killing it makes `wait` return a
            # signal code (143) — which under `set -e` would abort every SUCCESSFUL
            # run. The /dev/null redirect above is the real anti-hang guarantee;
            # this is prompt cleanup on top of it.
            pkill -P "$_watchdog_pid" 2>/dev/null || true
            kill "$_watchdog_pid" 2>/dev/null || true
            wait "$_watchdog_pid" 2>/dev/null || true

            if [ $_exit -eq 143 ] || [ $_exit -eq 137 ]; then
                # 143 = SIGTERM, 137 = SIGKILL
                log_error "Processing was stopped after ${timeout_human} timeout."
                log_error "Any files written before the timeout are still on disk."
                exit 1
            elif [ $_exit -ne 0 ]; then
                exit $_exit
            fi
            ;;
        process-last)
            # Find most recent recording in date/meeting subdirectories
            local latest_recording=""
            local latest_time=0

            # Search through all date directories and meeting subdirectories
            for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
                if [ ! -d "$date_dir" ]; then
                    continue
                fi

                for meeting_dir in "$date_dir"/meeting_*; do
                    if [ ! -d "$meeting_dir" ]; then
                        continue
                    fi

                    # Find .wav file in meeting directory
                    local wav_file=$(find "$meeting_dir" -name "*.wav" -type f | head -1)
                    if [ -n "$wav_file" ] && [ -f "$wav_file" ]; then
                        local file_time=$(stat -c %Y "$wav_file" 2>/dev/null || echo 0)
                        if [ "$file_time" -gt "$latest_time" ]; then
                            latest_time=$file_time
                            latest_recording="$wav_file"
                        fi
                    fi
                done
            done

            if [ -z "$latest_recording" ]; then
                log_error "No recordings found in $OUTPUT_DIR"
                exit 1
            fi

            log_info "Processing most recent recording: $(basename "$(dirname "$latest_recording")")/$(basename "$latest_recording")"

            # Call process command with the latest recording
            "$0" process "$latest_recording" "$@"
            ;;
        process-meeting)
            reprocess_meeting "$@"
            ;;
        full)
            full_workflow "$@"
            ;;
        meeting)
            meeting_ui "$@"
            ;;
        list)
            list_recordings
            ;;
        status)
            status_recordings
            ;;
        catchup)
            catchup_recordings "$@"
            ;;
        -h|--help)
            print_usage
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            print_usage
            exit 1
            ;;
    esac
}

# Run main() only when executed directly. When sourced (BASH_SOURCE != $0) the
# functions are defined without dispatching, so helpers such as the guided-flow
# confirm gate can be driven non-interactively from a test harness.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
