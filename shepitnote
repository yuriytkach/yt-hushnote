#!/bin/bash

# Complete meeting recording, transcription, and summarization workflow
# This script orchestrates all three steps: record -> transcribe -> summarize

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load config file if it exists
CONFIG_FILE="${SCRIPT_DIR}/.shepitnoterc"
if [ -f "$CONFIG_FILE" ]; then
    # Source the config file
    set -a  # Export all variables
    source "$CONFIG_FILE"
    set +a
fi

# The --no-diarize flag exports SHEPITNOTE_DIARIZE_OVERRIDE so it overrides
# DUAL_REMOTE_DIARIZATION even across process-last's re-invocation (the child
# re-sources .shepitnoterc above, which would otherwise reset the toggle back
# on). Applied here, after the config source, so the sentinel always wins.
if [ -n "${SHEPITNOTE_DIARIZE_OVERRIDE:-}" ]; then
    DUAL_REMOTE_DIARIZATION="$SHEPITNOTE_DIARIZE_OVERRIDE"
    export DUAL_REMOTE_DIARIZATION
fi

OUTPUT_DIR="${RECORDINGS_DIR:-${SCRIPT_DIR}/recordings}"
WHISPER_MODEL="${WHISPER_MODEL:-large-v3}"
WHISPER_LANGUAGE="${WHISPER_LANGUAGE:-}"
WHISPER_HOTWORDS="${WHISPER_HOTWORDS:-}"              # Space-separated tech terms to bias transcription spelling
WHISPER_INITIAL_PROMPT="${WHISPER_INITIAL_PROMPT:-}" # Sentence-form decoding bias (takes precedence over hotwords)
GLOSSARY_DIR="${GLOSSARY_DIR:-${SCRIPT_DIR}}"        # Directory of per-language glossary.<lang>.txt term files
ROSTER_DIR="${ROSTER_DIR:-${GLOSSARY_DIR}}"          # Directory holding roster.txt / roster.<name>.txt (known participants)
MEETING_ROSTER="${MEETING_ROSTER:-}"                 # Select a named roster.<name>.txt (empty = roster.txt; guided flow can ask)
MEETING_SELF_NAME="${MEETING_SELF_NAME:-}"           # Your name for the local mic ("You") track (roster ground truth)
MEETING_SELF_ROLE="${MEETING_SELF_ROLE:-}"           # Your role/title (used with MEETING_SELF_NAME)
OLLAMA_MODEL="${OLLAMA_MODEL:-llama3.1:8b}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"

# --- Cloud mode (opt-in; OFF by default) -------------------------------------
# Everything runs locally unless cloud mode is turned on with `--cloud` (per run)
# or CLOUD=true in .shepitnoterc. When on:
#   * summaries use CLOUD_SUMMARY_MODEL via Ollama Cloud (needs `ollama signin`);
#   * transcription uses a cloud Whisper API (default preset: Groq) IF a key is
#     set — otherwise it transparently falls back to local Whisper.
# Both providers expose OpenAI-compatible APIs, so any Whisper host works by
# editing the CLOUD_TRANSCRIBE_* preset. Cloud sends your transcript (and, for
# cloud transcription, your audio) off this machine — see docs/CLOUD.md.
CLOUD="${CLOUD:-false}"
LOCAL_SUMMARY_MODEL="$OLLAMA_MODEL"                       # remembered so --no-cloud can restore it
CLOUD_SUMMARY_MODEL="${CLOUD_SUMMARY_MODEL:-gpt-oss:120b-cloud}"
CLOUD_TRANSCRIBE_BASE_URL="${CLOUD_TRANSCRIBE_BASE_URL:-https://api.groq.com/openai/v1}"
CLOUD_TRANSCRIBE_MODEL="${CLOUD_TRANSCRIBE_MODEL:-whisper-large-v3}"
# Accept GROQ_API_KEY as a convenience alias for the generic key variable.
CLOUD_TRANSCRIBE_API_KEY="${CLOUD_TRANSCRIBE_API_KEY:-${GROQ_API_KEY:-}}"
# Whether cloud transcription follows the master switch. Empty = follow CLOUD;
# an explicit true/false in the environment always wins (e.g. cloud summary but
# local transcription).
CLOUD_TRANSCRIBE_EXPLICIT="${CLOUD_TRANSCRIBE:-}"
# Whether cloud SUMMARIZATION follows the master switch. Empty = follow CLOUD; an
# explicit true/false always wins — set false for cloud transcription with a
# LOCAL summary (often nicer notes). The mirror image of CLOUD_TRANSCRIBE above.
CLOUD_SUMMARIZE_EXPLICIT="${CLOUD_SUMMARIZE:-}"

_is_true() {
    case "$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')" in
        1|true|yes|on) return 0 ;;
        *) return 1 ;;
    esac
}

cloud_resolve() {
    # (Re)apply cloud settings from the current CLOUD value. Idempotent, so it
    # runs once at startup and again if --cloud/--no-cloud flips CLOUD. Every
    # value is exported so re-invoked children ("$0" process ...) and the Python
    # workers inherit the same decision.
    if _is_true "$CLOUD"; then
        if [ -n "$CLOUD_TRANSCRIBE_EXPLICIT" ]; then
            CLOUD_TRANSCRIBE="$CLOUD_TRANSCRIBE_EXPLICIT"
        else
            CLOUD_TRANSCRIBE="true"
        fi
        # Summarization is cloud by default in cloud mode, but an explicit false
        # (CLOUD_SUMMARIZE=false / --local-summary) keeps it on the local model —
        # e.g. cloud transcription for speed, local summary for nicer notes.
        if [ -n "$CLOUD_SUMMARIZE_EXPLICIT" ] && ! _is_true "$CLOUD_SUMMARIZE_EXPLICIT"; then
            CLOUD_SUMMARIZE="false"
            OLLAMA_MODEL="$LOCAL_SUMMARY_MODEL"
        else
            CLOUD_SUMMARIZE="true"
            OLLAMA_MODEL="$CLOUD_SUMMARY_MODEL"
        fi
    else
        CLOUD_TRANSCRIBE="false"
        CLOUD_SUMMARIZE="false"
        OLLAMA_MODEL="$LOCAL_SUMMARY_MODEL"
    fi
    export CLOUD CLOUD_TRANSCRIBE CLOUD_SUMMARIZE CLOUD_TRANSCRIBE_BASE_URL \
           CLOUD_TRANSCRIBE_MODEL CLOUD_TRANSCRIBE_API_KEY OLLAMA_MODEL
}
cloud_resolve

cloud_banner() {
    # One-time warning that data will leave the machine in cloud mode. The guard
    # is exported so a re-invoked child ("$0" process ...) does not repeat it.
    _is_true "$CLOUD" || return 0
    [ -n "${SHEPITNOTE_CLOUD_BANNER_SHOWN:-}" ] && return 0
    export SHEPITNOTE_CLOUD_BANNER_SHOWN=1
    log_warn "CLOUD MODE ON — data will leave this machine:"
    if _is_true "$CLOUD_SUMMARIZE"; then
        log_warn "  * Summary    -> Ollama Cloud model '${CLOUD_SUMMARY_MODEL}' (transcript uploaded)"
    else
        log_warn "  * Summary    -> LOCAL Ollama model '${LOCAL_SUMMARY_MODEL}' (stays on this machine)"
    fi
    if _is_true "$CLOUD_TRANSCRIBE"; then
        if [ -n "$CLOUD_TRANSCRIBE_API_KEY" ]; then
            log_warn "  * Transcribe -> ${CLOUD_TRANSCRIBE_MODEL} at ${CLOUD_TRANSCRIBE_BASE_URL} (audio uploaded)"
        else
            log_warn "  * Transcribe -> LOCAL Whisper (no CLOUD_TRANSCRIBE_API_KEY / GROQ_API_KEY set)"
        fi
    else
        log_warn "  * Transcribe -> LOCAL Whisper (cloud transcription disabled)"
    fi
}

PROCESS_TIMEOUT="${PROCESS_TIMEOUT:-7200}"  # Max seconds for process/process-last (default: 2h)
TRIM_NOISE_DB="${TRIM_NOISE_DB:--35}"       # dB threshold for silence detection (default: -35)
TRIM_MIN_SILENCE="${TRIM_MIN_SILENCE:-60}"  # Minimum silence duration in seconds (default: 60)
POST_SUMMARY_HOOK="${POST_SUMMARY_HOOK:-}"  # Script to run after summary is created; receives summary path as $1
DEBUG="${DEBUG:-false}"
PYTHON="${SCRIPT_DIR}/venv/bin/python3"

# --- CPU usage limits (keep the desktop responsive during processing) --------
# Post-meeting work (faster-whisper transcription, pyannote diarization, Ollama
# summarization) is CPU-heavy on a GPU-less machine. Two knobs keep it from
# taking the whole system hostage:
#   CPU_THREADS     — cap the worker thread pools so cores stay free for other
#                     apps (default: half the logical CPUs; min 1).
#   PROCESSING_NICE — scheduling niceness (0..19) applied to the heavy workers,
#                     so interactive apps always preempt them (default: 10).
# Raise CPU_THREADS / lower PROCESSING_NICE for faster processing; do the
# opposite to keep the machine snappier. Set CPU_THREADS=0 to leave everything
# uncapped (the libraries' own defaults).
_NCPU="$(nproc 2>/dev/null || echo 4)"
CPU_THREADS="${CPU_THREADS:-$(( _NCPU / 2 ))}"
# Only 0 (uncapped) or a positive integer are valid; anything else (empty,
# negative, non-numeric) falls back to the default. 0 is preserved so the export
# block below can skip capping entirely.
case "$CPU_THREADS" in ''|*[!0-9]*) CPU_THREADS="$(( _NCPU / 2 ))";; esac
PROCESSING_NICE="${PROCESSING_NICE:-10}"

# Export thread caps so every Python worker inherits them: OMP covers
# torch/pyannote and CTranslate2/faster-whisper; the BLAS vars cover numpy;
# OLLAMA_NUM_THREAD is forwarded into the Ollama request by summarize.py.
if [ "$CPU_THREADS" -gt 0 ]; then
    export CPU_THREADS
    export OMP_NUM_THREADS="$CPU_THREADS"
    export OPENBLAS_NUM_THREADS="$CPU_THREADS"
    export MKL_NUM_THREADS="$CPU_THREADS"
    export NUMEXPR_NUM_THREADS="$CPU_THREADS"
    export OLLAMA_NUM_THREAD="$CPU_THREADS"
fi

# Command prefix that runs a worker at lowered priority. Applied to the
# CPU-heavy workers (transcription, diarization) — not to recording.
NICE=()
if [ "${PROCESSING_NICE:-0}" -gt 0 ] 2>/dev/null; then
    NICE=(nice -n "$PROCESSING_NICE")
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

