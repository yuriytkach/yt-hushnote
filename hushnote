#!/bin/bash

# Complete meeting recording, transcription, and summarization workflow
# This script orchestrates all three steps: record -> transcribe -> summarize

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load config file if it exists
CONFIG_FILE="${SCRIPT_DIR}/.hushnoterc"
if [ -f "$CONFIG_FILE" ]; then
    # Source the config file
    set -a  # Export all variables
    source "$CONFIG_FILE"
    set +a
fi

OUTPUT_DIR="${RECORDINGS_DIR:-${SCRIPT_DIR}/recordings}"
WHISPER_MODEL="${WHISPER_MODEL:-large-v3}"
WHISPER_LANGUAGE="${WHISPER_LANGUAGE:-}"
WHISPER_HOTWORDS="${WHISPER_HOTWORDS:-}"              # Space-separated tech terms to bias transcription spelling
WHISPER_INITIAL_PROMPT="${WHISPER_INITIAL_PROMPT:-}" # Sentence-form decoding bias (takes precedence over hotwords)
GLOSSARY_DIR="${GLOSSARY_DIR:-${SCRIPT_DIR}}"        # Directory of per-language glossary.<lang>.txt term files
OLLAMA_MODEL="${OLLAMA_MODEL:-llama3.1:8b}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
PROCESS_TIMEOUT="${PROCESS_TIMEOUT:-7200}"  # Max seconds for process/process-last (default: 2h)
TRIM_NOISE_DB="${TRIM_NOISE_DB:--35}"       # dB threshold for silence detection (default: -35)
TRIM_MIN_SILENCE="${TRIM_MIN_SILENCE:-60}"  # Minimum silence duration in seconds (default: 60)
POST_SUMMARY_HOOK="${POST_SUMMARY_HOOK:-}"  # Script to run after summary is created; receives summary path as $1
DEBUG="${DEBUG:-false}"
PYTHON="${SCRIPT_DIR}/venv/bin/python3"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_usage() {
    cat << EOF
Usage: $0 [COMMAND] [OPTIONS]

Commands:
    record              Start recording a meeting
    transcribe FILE     Transcribe an audio file
    summarize FILE      Summarize a transcription
    diarize FILE        Identify speakers in an audio file
    label FILE          Label speakers with their names (interactive)
    apply-labels FILE   Apply speaker labels to create final transcript
    trim FILE           Detect and remove silent tail from an audio file
    compress FILE       Compress WAV to MP3 and delete WAV
    clean FILE          Delete ALL audio files (WAV and MP3)
    full               Complete workflow: record, transcribe, and summarize
    process FILE        Process existing recording (transcribe + diarize + summarize)
    process-last        Process most recent recording (transcribe + diarize + summarize)
    list               List all recordings
    status             Show status of all recordings (what needs processing)
    catchup            Process all unfinished recordings and run post-summary hook

Options:
    -d, --duration SEC  Recording duration in seconds (default: manual stop with Ctrl+C)
    -m, --model MODEL   Whisper model size: tiny, base, small, medium, large-v3 (default: large-v3)
    -l, --language LANG Language code, e.g. uk, ru, en, or auto (default: auto-detect)
    --initial-prompt T  Decoding-bias sentence for tech-term spelling (overrides --hotwords)
    --hotwords TERMS    Space-separated tech terms to bias transcription spelling
    -o, --ollama MODEL  Ollama model for summarization (default: llama3.1:8b)
    -f, --format FMT    Output format: txt, json, srt, vtt, md (default: txt for transcribe, md for summarize)
    -s, --speakers NUM  Number of speakers (for diarization)
    -t, --title TITLE   Meeting title (prompted if not provided)
    --diarize           Enable speaker diarization in full workflow
    --no-compress       Skip MP3 compression (keep WAV only)
    --keep-wav          Keep WAV file after compression (default: delete WAV)
    --no-trim           Skip silent tail trimming
    --keep-untrimmed    Keep full MP3 alongside trimmed version (default: delete)
    --keep-trimmed      Keep trimmed MP3 after transcription (default: keep)
    --clean             Delete ALL audio files (WAV and MP3), keep only text
    -h, --help          Show this help message

Environment Variables:
    RECORDINGS_DIR      Directory for recordings (default: ./recordings)
    AUDIO_SOURCE_TYPE   Capture mode: microphone (default), monitor, both, or
                        dual. dual records separate You (mic) and Remote (system)
                        tracks and labels the transcript by origin, no diarization.
    WHISPER_MODEL       Default Whisper model (default: large-v3)
    WHISPER_LANGUAGE    Default language code, e.g. uk, ru, en (default: auto-detect)
    WHISPER_HOTWORDS    Space-separated tech terms biasing transcription toward
                        clean English spellings (default: none)
    WHISPER_INITIAL_PROMPT  Sentence-form decoding bias; takes precedence over
                        WHISPER_HOTWORDS (default: none)
    GLOSSARY_DIR        Directory of per-language glossary.<lang>.txt files applied
                        to the transcript before summarizing (default: script dir)
    OLLAMA_MODEL        Default Ollama model (default: llama3.1:8b)
    OLLAMA_URL          Ollama API URL (default: http://localhost:11434)
    HF_TOKEN            HuggingFace API token (for speaker diarization)
    PROCESS_TIMEOUT     Max seconds for process/process-last before auto-kill (default: 7200)
    TRIM_NOISE_DB       Silence threshold in dB for tail trimming (default: -35)
    TRIM_MIN_SILENCE    Minimum silence duration in seconds to consider a tail (default: 60)
    POST_SUMMARY_HOOK   Executable to run after summary is created; receives summary path as \$1
    DEBUG               Enable debug output (set to 'true' to enable)

Examples:
    # Record a meeting (stop with Ctrl+C)
    $0 record

    # Record for 1 hour
    $0 record -d 3600

    # Transcribe an audio file
    $0 transcribe recordings/meeting_20251005_143022.wav

    # Complete workflow: record, transcribe, and summarize
    $0 full

    # List all recordings
    $0 list
EOF
}

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_debug() {
    if [ "$DEBUG" = "true" ]; then
        echo -e "[DEBUG] $1" >&2
    fi
}

check_dependencies() {
    local missing=()

    if ! command -v ffmpeg &> /dev/null; then
        missing+=("ffmpeg")
    fi

    if ! command -v pactl &> /dev/null; then
        missing+=("pactl (pulseaudio-utils or pipewire-pulse)")
    fi

    if ! command -v python3 &> /dev/null; then
        missing+=("python3")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies: ${missing[*]}"
        exit 1
    fi
}

record_meeting() {
    local duration=""
    local output_file=""
    local title=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--duration)
                duration="$2"
                shift 2
                ;;
            -o|--output)
                output_file="$2"
                shift 2
                ;;
            -t|--title)
                title="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    log_info "Starting meeting recording..."

    # Build command arguments
    local record_args=()
    [ -n "$duration" ] && record_args+=("-d" "$duration")
    [ -n "$output_file" ] && record_args+=("-o" "$output_file")
    [ -n "$title" ] && record_args+=("-t" "$title")

    # Run recording and capture output file path
    # Use temp file to avoid command substitution exit on CTRL-C
    local record_result_file="/tmp/hushnote_record_$$"
    local record_exit_code=0

    "${SCRIPT_DIR}/record_audio.sh" "${record_args[@]}" > "$record_result_file" || record_exit_code=$?

    # Read the output file path
    if [ -f "$record_result_file" ]; then
        output_file=$(cat "$record_result_file")
        rm -f "$record_result_file"
    fi

    # Debug output
    log_debug "Recording exit code: $record_exit_code"
    log_debug "Captured output_file=[$output_file]"
    log_debug "File exists check: $([ -f "$output_file" ] && echo YES || echo NO)"

    if [ -n "$output_file" ] && [ -f "$output_file" ]; then
        log_success "Recording complete: $output_file"
        echo "$output_file"
    else
        log_error "Failed to capture recording output or file doesn't exist"
        return 1
    fi
}

detect_dual_tracks() {
    # Given any track path (voice/system/plain wav or mp3), resolve the meeting
    # base and echo it iff BOTH the voice and system WAV tracks exist. Echoes
    # nothing otherwise, so callers can test with [ -n "$(detect_dual_tracks ...)" ].
    local path="$1"
    local base
    case "$path" in
        *.voice.wav)  base="${path%.voice.wav}" ;;
        *.system.wav) base="${path%.system.wav}" ;;
        *)            base="${path%.*}" ;;
    esac

    if [ -f "${base}.voice.wav" ] && [ -f "${base}.system.wav" ]; then
        echo "$base"
    fi
}

transcribe_meeting() {
    local audio_file="$1"
    shift

    local model="$WHISPER_MODEL"
    local language="$WHISPER_LANGUAGE"
    local initial_prompt="$WHISPER_INITIAL_PROMPT"
    local hotwords="$WHISPER_HOTWORDS"
    local format="txt"
    local output=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -m|--model)
                model="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --initial-prompt)
                initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                hotwords="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -o|--output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Transcribing audio file: $audio_file"
    log_info "Using Whisper model: $model"
    [ -n "$language" ] && log_info "Language: $language"

    # Derive output path, stripping _trimmed suffix so transcripts are named
    # after the meeting base rather than the trimmed audio file.
    if [ -z "$output" ]; then
        local base="${audio_file%.*}"
        base="${base%_trimmed}"
        output="${base}.${format}"
    fi

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/transcribe.py\" \"$audio_file\" -m $model -f $format -o \"$output\""
    [ -n "$language" ] && cmd="$cmd -l $language"
    # initial_prompt/hotwords are free text (spaces/quotes); %q-quote so they
    # survive the eval as single arguments.
    [ -n "$initial_prompt" ] && cmd="$cmd --initial-prompt $(printf %q "$initial_prompt")"
    [ -n "$hotwords" ] && cmd="$cmd --hotwords $(printf %q "$hotwords")"

    eval $cmd

    if [ -f "$output" ]; then
        log_success "Transcription complete: $output"
        echo "$output"
    else
        log_error "Transcription output file not created: $output"
        return 1
    fi
}

summarize_meeting() {
    local transcription_file="$1"
    shift

    local model="$OLLAMA_MODEL"
    local format="md"
    local output=""
    local language=""
    local glossary_dir="$GLOSSARY_DIR"

    while [[ $# -gt 0 ]]; do
        case $1 in
            -o|--ollama)
                model="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --glossary-dir)
                glossary_dir="$2"
                shift 2
                ;;
            --output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$transcription_file" ]; then
        log_error "Transcription file not found: $transcription_file"
        exit 1
    fi

    log_info "Summarizing transcription: $transcription_file"
    log_info "Using Ollama model: $model"

    # Derive output path, stripping _trimmed suffix so summaries are named
    # after the meeting base rather than the trimmed file.
    if [ -z "$output" ]; then
        local base="${transcription_file%.*}"
        base="${base%_trimmed}"
        output="${base}_summary.${format}"
    fi

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/summarize.py\" \"$transcription_file\" -m $model -f $format -o \"$output\""
    # Language selects the per-language glossary (issue #8); when empty,
    # summarize.py falls back to the language recorded in the sibling JSON, then
    # to the union of all glossary files. glossary_dir is a path -> quote it.
    [ -n "$language" ] && cmd="$cmd -l $language"
    [ -n "$glossary_dir" ] && cmd="$cmd --glossary-dir $(printf %q "$glossary_dir")"

    eval $cmd

    if [ -f "$output" ]; then
        log_success "Summary complete: $output"
        echo "$output"
    fi
}

full_workflow() {
    # Parse arguments for full workflow
    local duration=""
    local whisper_model="$WHISPER_MODEL"
    local whisper_language="$WHISPER_LANGUAGE"
    local whisper_initial_prompt="$WHISPER_INITIAL_PROMPT"
    local whisper_hotwords="$WHISPER_HOTWORDS"
    local ollama_model="$OLLAMA_MODEL"
    local format=""
    local enable_diarization=false
    local num_speakers=""
    local enable_compression=true
    local keep_wav=false
    local clean_all=false
    local title=""
    local enable_trim=true
    local keep_untrimmed=false
    local keep_trimmed=true

    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--duration)
                duration="$2"
                shift 2
                ;;
            -m|--model)
                whisper_model="$2"
                shift 2
                ;;
            -l|--language)
                whisper_language="$2"
                shift 2
                ;;
            --initial-prompt)
                whisper_initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                whisper_hotwords="$2"
                shift 2
                ;;
            -o|--ollama)
                ollama_model="$2"
                shift 2
                ;;
            -f|--format)
                format="$2"
                shift 2
                ;;
            -t|--title)
                title="$2"
                shift 2
                ;;
            --diarize)
                enable_diarization=true
                shift
                ;;
            -s|--speakers)
                num_speakers="$2"
                shift 2
                ;;
            --no-compress)
                enable_compression=false
                shift
                ;;
            --keep-wav)
                keep_wav=true
                shift
                ;;
            --no-trim)
                enable_trim=false
                shift
                ;;
            --keep-untrimmed)
                keep_untrimmed=true
                shift
                ;;
            --keep-trimmed)
                keep_trimmed=true
                shift
                ;;
            --clean)
                clean_all=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ "$enable_diarization" = true ]; then
        log_info "Starting full meeting workflow with speaker diarization..."
    else
        log_info "Starting full meeting workflow..."
    fi
    echo ""

    # Step 1: Record
    log_info "Step 1: Recording audio..."
    local audio_file

    # Record the audio
    # Use a temporary file to communicate the recording path
    local recording_result_file="/tmp/hushnote_recording_$$"
    local recording_exit_code=0

    # Build record_meeting arguments
    local record_args=()
    [ -n "$duration" ] && record_args+=("-d" "$duration")
    [ -n "$title" ] && record_args+=("-t" "$title")

    if [ -n "$duration" ]; then
        record_meeting "${record_args[@]}" > "$recording_result_file"
        recording_exit_code=$?
    else
        # For open-ended recording, call in a way that captures exit code but continues
        # The || true prevents set -e from exiting, then we check the actual exit code
        record_meeting "${record_args[@]}" > "$recording_result_file" || recording_exit_code=$?

        log_debug "Recording exit code: $recording_exit_code"

        # If recording was stopped (non-zero exit is expected with CTRL-C)
        if [ $recording_exit_code -ne 0 ]; then
            echo "" >&2
            log_info "Recording stopped. Continuing with processing..." >&2
            echo "" >&2
        fi
    fi

    # Read the audio file path from the result file
    if [ -f "$recording_result_file" ]; then
        audio_file=$(cat "$recording_result_file")
        rm -f "$recording_result_file"
    else
        audio_file=""
    fi

    log_debug "Audio file captured: [$audio_file]"

    if [ -z "$audio_file" ] || [ ! -f "$audio_file" ]; then
        log_error "Recording failed or no audio file was created"
        log_error "Exit code was: $recording_exit_code"
        log_error "Audio file variable: [$audio_file]"
        exit 1
    fi

    echo ""

    # Dual-track recording (AUDIO_SOURCE_TYPE=dual): two synced tracks were
    # recorded (voice=You, system=Remote). Detect the pair from the returned
    # voice-track path and process it without diarization.
    local dual_base
    dual_base=$(detect_dual_tracks "$audio_file")
    if [ -n "$dual_base" ]; then
        local dual_args=(-m "$whisper_model")
        [ -n "$whisper_language" ] && dual_args+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && dual_args+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && dual_args+=(--hotwords "$whisper_hotwords")
        [ -n "$ollama_model" ] && dual_args+=(-o "$ollama_model")
        [ "$enable_compression" = false ] && dual_args+=(--no-compress)
        [ "$keep_wav" = true ] && dual_args+=(--keep-wav)
        [ "$clean_all" = true ] && dual_args+=(--clean)
        process_dual_meeting "$dual_base" "${dual_args[@]}"
        return 0
    fi

    if [ "$enable_diarization" = true ]; then
        # Diarization workflow: 7 steps

        # Step 2: Diarize
        log_info "Step 2: Identifying speakers..."
        local speakers_file
        if [ -n "$num_speakers" ]; then
            speakers_file=$(diarize_meeting "$audio_file" -s "$num_speakers")
        else
            speakers_file=$(diarize_meeting "$audio_file")
        fi

        if [ -z "$speakers_file" ] || [ ! -f "$speakers_file" ]; then
            log_error "Diarization failed"
            exit 1
        fi

        echo ""

        # Step 3: Transcribe (as JSON for merging)
        log_info "Step 3: Transcribing audio..."
        local base="${audio_file%.*}"
        local transcription_json="${base}.json"

        local transcribe_cmd=("$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$audio_file" -m "$whisper_model" -f json -o "$transcription_json")
        [ -n "$whisper_language" ] && transcribe_cmd+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && transcribe_cmd+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && transcribe_cmd+=(--hotwords "$whisper_hotwords")
        "${transcribe_cmd[@]}"

        if [ ! -f "$transcription_json" ]; then
            log_error "Transcription failed"
            exit 1
        fi

        echo ""

        # Step 4: Merge diarization + transcription
        log_info "Step 4: Merging speaker info with transcription..."
        local diarized_file="${base}_diarized.json"

        "$PYTHON" "${SCRIPT_DIR}/merge_diarization.py" "$speakers_file" "$transcription_json" -o "$diarized_file"

        if [ ! -f "$diarized_file" ]; then
            log_error "Merge failed"
            exit 1
        fi

        echo ""

        # Step 5: Label speakers interactively
        log_info "Step 5: Label speakers with their names..."
        echo ""

        # Call label_speakers without command substitution to allow interactive input
        label_speakers "$diarized_file"

        # Determine output file manually
        local base="${diarized_file%_diarized.json}"
        local labeled_file="${base}_speakers_labeled.json"

        if [ ! -f "$labeled_file" ]; then
            log_error "Labeling failed"
            exit 1
        fi

        echo ""

        # Step 6: Apply labels to create final transcript
        log_info "Step 6: Creating final transcript with speaker names..."
        local transcription_file=$(apply_speaker_labels "$labeled_file" -f txt)

        if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
            log_error "Apply labels failed"
            exit 1
        fi

        echo ""

        # Step 7: Summarize
        log_info "Step 7: Generating summary..."
        local summary_file
        local summarize_args=()
        [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
        [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
        summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

        if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
            log_error "Summarization failed"
            exit 1
        fi

        echo ""

        # Step 8: Compress audio and cleanup
        if [ "$clean_all" = true ]; then
            log_info "Step 8: Removing all audio files..."
            # Delete both WAV and MP3 if they exist
            [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
            local mp3_file="${audio_file%.wav}.mp3"
            [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
            audio_file="(deleted)"
            echo ""
        elif [ "$enable_compression" = true ]; then
            log_info "Step 8: Compressing audio to MP3..."
            local mp3_file
            if [ "$keep_wav" = true ]; then
                mp3_file=$(compress_audio "$audio_file")
            else
                # Default: delete WAV after compression
                mp3_file=$(compress_audio "$audio_file" --delete-wav)
            fi

            if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                audio_file="$mp3_file"
            fi
            echo ""
        fi

        log_success "Complete workflow with diarization finished!"
        echo ""
        echo "Files generated:"
        echo "  Audio:          $audio_file"
        echo "  Diarization:    $speakers_file"
        echo "  Labeled:        $labeled_file"
        echo "  Transcription:  $transcription_file"
        echo "  Summary:        $summary_file"
    else
        # Standard workflow without diarization

        # Step 2: Compress WAV → MP3 and delete WAV
        local mp3_file=""
        local transcribe_source="$audio_file"
        if [ "$clean_all" = true ]; then
            log_info "Step 2/5: Skipping compression (--clean mode, audio will be deleted)"
        elif [ "$enable_compression" = true ]; then
            log_info "Step 2/5: Compressing audio to MP3..."
            if [ "$keep_wav" = true ]; then
                mp3_file=$(compress_audio "$audio_file")
            else
                mp3_file=$(compress_audio "$audio_file" --delete-wav)
            fi
            if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                transcribe_source="$mp3_file"
            fi
            echo ""
        fi

        # Step 3: Trim silent tail
        local trimmed_file=""
        if [ "$enable_trim" = true ] && [ -f "$transcribe_source" ]; then
            log_info "Step 3/5: Trimming silent tail..."
            trimmed_file=$(trim_audio "$transcribe_source")
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                transcribe_source="$trimmed_file"
            fi
            echo ""
        fi

        # Step 4: Transcribe
        log_info "Step 4/5: Transcribing audio..."
        local transcription_file
        local transcribe_args=()
        [ -n "$whisper_model" ] && transcribe_args+=(-m "$whisper_model")
        [ -n "$whisper_language" ] && transcribe_args+=(-l "$whisper_language")
        [ -n "$whisper_initial_prompt" ] && transcribe_args+=(--initial-prompt "$whisper_initial_prompt")
        [ -n "$whisper_hotwords" ] && transcribe_args+=(--hotwords "$whisper_hotwords")
        transcription_file=$(transcribe_meeting "$transcribe_source" "${transcribe_args[@]}")

        log_debug "Transcription file captured: [$transcription_file]"

        if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
            log_error "Transcription failed - file not found: $transcription_file"
            exit 1
        fi

        echo ""

        # Step 5: Summarize
        log_info "Step 5/5: Generating summary..."
        local summary_file
        local summarize_args=()
        [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
        [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
        summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

        if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
            log_error "Summarization failed"
            exit 1
        fi

        echo ""

        # Cleanup audio
        if [ "$clean_all" = true ]; then
            log_info "Removing all audio files..."
            [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
            [ -n "$mp3_file" ] && [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
            [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && rm "$trimmed_file" && log_success "Deleted: $trimmed_file"
            audio_file="(deleted)"
            echo ""
        else
            # Delete untrimmed MP3 unless --keep-untrimmed
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                if [ "$keep_untrimmed" = false ]; then
                    rm "$mp3_file" && log_info "Deleted untrimmed: $mp3_file (use --keep-untrimmed to keep)"
                fi
            fi
            # Delete trimmed MP3 if --keep-trimmed is false
            if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                if [ "$keep_trimmed" = false ]; then
                    rm "$trimmed_file" && log_info "Deleted trimmed audio: $trimmed_file"
                fi
            fi
        fi

        log_success "Complete workflow finished!"
        echo ""
        echo "Files generated:"
        [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && echo "  Audio (trimmed):    $trimmed_file"
        [ -n "$mp3_file" ] && [ -f "$mp3_file" ] && echo "  Audio (full):       $mp3_file"
        echo "  Transcription:      $transcription_file"
        echo "  Summary:            $summary_file"

        run_post_summary_hook "$summary_file" && \
            touch "${summary_file%_summary.md}.hook_done" || true
    fi
}

process_dual_meeting() {
    # Process a dual-track recording: transcribe the voice (You) and system
    # (Remote) tracks separately, tag each segment by track of origin, merge by
    # timestamp, then render and summarize. No diarization is used for You vs
    # Remote — that split comes from the two physical tracks.
    local base="$1"
    shift

    local model="$WHISPER_MODEL"
    local language="$WHISPER_LANGUAGE"
    local initial_prompt="$WHISPER_INITIAL_PROMPT"
    local hotwords="$WHISPER_HOTWORDS"
    local ollama_model="$OLLAMA_MODEL"
    local enable_compression=true
    local keep_wav=false
    local clean_all=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -m|--model)
                model="$2"
                shift 2
                ;;
            -l|--language)
                language="$2"
                shift 2
                ;;
            --initial-prompt)
                initial_prompt="$2"
                shift 2
                ;;
            --hotwords)
                hotwords="$2"
                shift 2
                ;;
            -o|--ollama)
                ollama_model="$2"
                shift 2
                ;;
            --no-compress)
                enable_compression=false
                shift
                ;;
            --keep-wav)
                keep_wav=true
                shift
                ;;
            --clean)
                clean_all=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local voice_wav="${base}.voice.wav"
    local system_wav="${base}.system.wav"

    if [ ! -f "$voice_wav" ] || [ ! -f "$system_wav" ]; then
        log_error "Dual tracks not found for: $(basename "$base")"
        return 1
    fi

    log_info "Processing dual-track recording: $(basename "$base")"
    log_info "Using Whisper model: $model"
    [ -n "$language" ] && log_info "Language: $language"
    echo ""

    # Step 1: Transcribe the voice track (You).
    log_info "Step 1: Transcribing voice track (You)..."
    local voice_json="${base}.voice.json"
    local voice_cmd=("$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$voice_wav" -m "$model" -f json -o "$voice_json")
    [ -n "$language" ] && voice_cmd+=(-l "$language")
    [ -n "$initial_prompt" ] && voice_cmd+=(--initial-prompt "$initial_prompt")
    [ -n "$hotwords" ] && voice_cmd+=(--hotwords "$hotwords")
    "${voice_cmd[@]}"

    if [ ! -f "$voice_json" ]; then
        log_error "Voice track transcription failed"
        return 1
    fi
    echo ""

    # Step 2: Transcribe the system track (Remote).
    log_info "Step 2: Transcribing system track (Remote)..."
    local system_json="${base}.system.json"
    local system_cmd=("$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$system_wav" -m "$model" -f json -o "$system_json")
    [ -n "$language" ] && system_cmd+=(-l "$language")
    [ -n "$initial_prompt" ] && system_cmd+=(--initial-prompt "$initial_prompt")
    [ -n "$hotwords" ] && system_cmd+=(--hotwords "$hotwords")
    "${system_cmd[@]}"

    if [ ! -f "$system_json" ]; then
        log_error "System track transcription failed"
        return 1
    fi
    echo ""

    # Step 3: Merge tracks — label by origin (You vs Remote), no diarization.
    log_info "Step 3: Merging tracks (You vs Remote)..."
    local labeled_file="${base}_speakers_labeled.json"
    "$PYTHON" "${SCRIPT_DIR}/merge_tracks.py" \
        --voice "$voice_json" --system "$system_json" \
        --audio-file "$(basename "$voice_wav")" -o "$labeled_file"

    if [ ! -f "$labeled_file" ]; then
        log_error "Track merge failed"
        return 1
    fi
    echo ""

    # Step 4: Render final transcript named after the meeting base so status/
    # list see meeting_TS.txt.
    log_info "Step 4: Creating final transcript with You/Remote labels..."
    local transcription_file="${base}.txt"
    apply_speaker_labels "$labeled_file" -f txt -o "$transcription_file" >/dev/null

    if [ ! -f "$transcription_file" ]; then
        log_error "Apply labels failed"
        return 1
    fi
    echo ""

    # Step 5: Summarize.
    log_info "Step 5: Generating summary..."
    local summary_file
    local summarize_args=()
    [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
    [ -n "$language" ] && summarize_args+=(-l "$language")
    summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

    if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
        log_error "Summarization failed"
        return 1
    fi
    echo ""

    # Step 6: Compress or clean each track. Silent-tail trimming is skipped in
    # dual mode — per-track trimming would desync turn ordering.
    local voice_audio="$voice_wav"
    local system_audio="$system_wav"
    if [ "$clean_all" = true ]; then
        log_info "Step 6: Removing all audio files..."
        [ -f "$voice_wav" ]  && rm "$voice_wav"  && log_success "Deleted: $voice_wav"
        [ -f "$system_wav" ] && rm "$system_wav" && log_success "Deleted: $system_wav"
        [ -f "${base}.voice.mp3" ]  && rm "${base}.voice.mp3"  && log_success "Deleted: ${base}.voice.mp3"
        [ -f "${base}.system.mp3" ] && rm "${base}.system.mp3" && log_success "Deleted: ${base}.system.mp3"
        voice_audio="(deleted)"
        system_audio="(deleted)"
        echo ""
    elif [ "$enable_compression" = true ]; then
        log_info "Step 6: Compressing tracks to MP3..."
        local mp3
        if [ "$keep_wav" = true ]; then
            mp3=$(compress_audio "$voice_wav")
            [ -n "$mp3" ] && [ -f "$mp3" ] && voice_audio="$mp3"
            mp3=$(compress_audio "$system_wav")
            [ -n "$mp3" ] && [ -f "$mp3" ] && system_audio="$mp3"
        else
            mp3=$(compress_audio "$voice_wav" --delete-wav)
            [ -n "$mp3" ] && [ -f "$mp3" ] && voice_audio="$mp3"
            mp3=$(compress_audio "$system_wav" --delete-wav)
            [ -n "$mp3" ] && [ -f "$mp3" ] && system_audio="$mp3"
        fi
        echo ""
    fi

    log_success "Dual-track processing complete!"
    echo ""
    echo "Files generated:"
    echo "  Audio (voice/You):     $voice_audio"
    echo "  Audio (system/Remote): $system_audio"
    echo "  Labeled:               $labeled_file"
    echo "  Transcription:         $transcription_file"
    echo "  Summary:               $summary_file"

    run_post_summary_hook "$summary_file" && \
        touch "${summary_file%_summary.md}.hook_done" || true
}

diarize_meeting() {
    local audio_file="$1"
    shift

    local speakers=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--speakers)
                speakers="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Identifying speakers in: $audio_file"

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/diarize.py\" \"$audio_file\""
    [ -n "$speakers" ] && cmd="$cmd -s $speakers"

    eval $cmd

    # Determine output file
    local base="${audio_file%.*}"
    local output="${base}_speakers.json"

    if [ -f "$output" ]; then
        log_success "Diarization complete: $output"
        echo "$output"
    fi
}

label_speakers() {
    local diarized_file="$1"
    shift

    if [ ! -f "$diarized_file" ]; then
        log_error "Diarized file not found: $diarized_file"
        exit 1
    fi

    log_info "Labeling speakers in: $diarized_file"
    echo ""

    # Run label.py interactively (don't capture output)
    "$PYTHON" "${SCRIPT_DIR}/label.py" "$diarized_file" </dev/tty

    # Determine output file
    local base="${diarized_file%_diarized.json}"
    local output="${base}_speakers_labeled.json"

    if [ -f "$output" ]; then
        echo ""
        log_success "Labeling complete: $output"
        echo "$output"
    fi
}

apply_speaker_labels() {
    local labeled_file="$1"
    shift

    local format="txt"
    local output=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--format)
                format="$2"
                shift 2
                ;;
            -o|--output)
                output="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$labeled_file" ]; then
        log_error "Labeled file not found: $labeled_file"
        exit 1
    fi

    log_info "Applying labels to transcript: $labeled_file"

    local cmd="\"$PYTHON\" \"${SCRIPT_DIR}/apply_labels.py\" \"$labeled_file\" -f $format"
    [ -n "$output" ] && cmd="$cmd -o \"$output\""

    eval $cmd

    # Determine output file
    if [ -z "$output" ]; then
        # Extract base name from labeled file
        local base=$(basename "$labeled_file" "_speakers_labeled.json")
        base="${base%.json}"
        output="$(dirname "$labeled_file")/${base}.${format}"
    fi

    if [ -f "$output" ]; then
        log_success "Transcript complete: $output"
        echo "$output"
    fi
}

compress_audio() {
    local audio_file="$1"
    shift

    local delete_wav=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --delete-wav|--clean)
                delete_wav=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Compressing audio: $audio_file"

    local compress_args=("${SCRIPT_DIR}/compress.sh" "$audio_file")
    [ "$delete_wav" = true ] && compress_args+=(--delete-wav)

    local mp3_file
    mp3_file=$("${compress_args[@]}")

    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
        log_success "Compression complete: $mp3_file"
        echo "$mp3_file"
    fi
}

trim_audio() {
    local audio_file="$1"
    shift

    local noise_threshold="${TRIM_NOISE_DB:--35}"
    local min_silence="${TRIM_MIN_SILENCE:-60}"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --noise)
                noise_threshold="$2"
                shift 2
                ;;
            --min-silence)
                min_silence="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ ! -f "$audio_file" ]; then
        log_error "Audio file not found: $audio_file"
        exit 1
    fi

    log_info "Scanning for silent tail: $audio_file (noise=${noise_threshold}dB, min-silence=${min_silence}s)"

    local total_duration
    total_duration=$(ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$audio_file" 2>/dev/null)

    if [ -z "$total_duration" ]; then
        log_warn "Could not determine duration, skipping trim"
        echo "$audio_file"
        return 0
    fi

    local total_int
    total_int=$(python3 -c "print(int(float('$total_duration')))")

    # Window size for each probe: 5 minutes
    local window=300

    # Binary search for the last position that contains content.
    # lo = last known position with content, hi = first known silent position.
    # We probe the midpoint each iteration.
    local lo=0
    local hi=$total_int

    # Confirm content exists at the very start before searching
    local first_output
    first_output=$(ffmpeg -ss 0 -t $window -i "$audio_file" \
        -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

    local first_sil_at_start
    first_sil_at_start=$(echo "$first_output" | grep -oP 'silence_start: \K[\d.]+' | head -1 || true)

    local start_has_content=false
    if [ -z "$first_sil_at_start" ]; then
        start_has_content=true
    elif python3 -c "exit(0 if float('$first_sil_at_start') > 5 else 1)" 2>/dev/null; then
        start_has_content=true
    fi

    if [ "$start_has_content" = false ]; then
        log_warn "No content found in first ${window}s — skipping trim"
        echo "$audio_file"
        return 0
    fi

    log_debug "Binary search: lo=${lo}s hi=${hi}s total=${total_int}s"

    local iterations=0
    while [ $((hi - lo)) -gt $window ] && [ $iterations -lt 12 ]; do
        iterations=$((iterations + 1))
        local mid=$(( (lo + hi) / 2 ))

        local output
        output=$(ffmpeg -ss "$mid" -t $window -i "$audio_file" \
            -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

        # Window has content if: no silence detected at all, or first silence
        # starts more than 5s in (meaning content preceded it).
        # A silence_end alone does NOT mean content — it just means the silence
        # block closed at the window boundary (entire window was silent).
        local has_content=false
        local first_sil
        first_sil=$(echo "$output" | grep -oP 'silence_start: \K[\d.]+' | head -1 || true)

        if [ -z "$first_sil" ]; then
            has_content=true
        elif python3 -c "exit(0 if float('$first_sil') > 5 else 1)" 2>/dev/null; then
            has_content=true
        fi

        if [ "$has_content" = true ]; then
            lo=$mid
            log_debug "  mid=${mid}s → content found, lo=${lo}s"
        else
            hi=$mid
            log_debug "  mid=${mid}s → silent, hi=${hi}s"
        fi
    done

    # lo is the last window start known to have content.
    # Scan that window precisely to find where content ends within it.
    local final_output
    final_output=$(ffmpeg -ss "$lo" -t $window -i "$audio_file" \
        -af "silencedetect=noise=${noise_threshold}dB:duration=${min_silence}" -f null - 2>&1)

    local last_silence_start_in_window
    last_silence_start_in_window=$(echo "$final_output" | grep -oP 'silence_start: \K[\d.]+' | tail -1 || true)

    local last_content_end
    if [ -n "$last_silence_start_in_window" ]; then
        # Add 2s buffer so we don't cut the last word
        last_content_end=$(python3 -c "print(min(float('$total_duration'), $lo + float('$last_silence_start_in_window') + 2))")
    else
        # No silence in final window — content runs to end of it
        last_content_end=$(python3 -c "print(min(float('$total_duration'), $lo + $window))")
    fi

    local total_min
    total_min=$(python3 -c "print(round(float('$total_duration') / 60, 1))")
    local trim_min
    trim_min=$(python3 -c "print(round(float('$last_content_end') / 60, 1))")
    local saved_min
    saved_min=$(python3 -c "print(round((float('$total_duration') - float('$last_content_end')) / 60, 1))")

    if python3 -c "exit(0 if float('$saved_min') < 1 else 1)" 2>/dev/null; then
        log_info "Less than 1 min to trim — skipping (${total_min}min recording)"
        echo "$audio_file"
        return 0
    fi

    log_info "Trimming ${total_min}min → ${trim_min}min (saves ${saved_min}min)"

    local ext="${audio_file##*.}"
    local base="${audio_file%.*}"
    local trimmed_file="${base}_trimmed.${ext}"

    ffmpeg -i "$audio_file" -t "$last_content_end" -codec:a copy -y "$trimmed_file" 2>/dev/null

    if [ ! -f "$trimmed_file" ]; then
        log_error "Trim failed"
        return 1
    fi

    log_success "Trimmed audio: $trimmed_file"
    echo "$trimmed_file"
}

clean_audio() {
    local audio_file="$1"

    # Determine base path and possible audio files
    local base_path="${audio_file%.wav}"
    base_path="${base_path%.mp3}"
    local wav_file="${base_path}.wav"
    local mp3_file="${base_path}.mp3"

    local deleted_count=0

    log_info "Removing all audio files for: $(basename "$base_path")"

    # Delete WAV if exists
    if [ -f "$wav_file" ]; then
        rm "$wav_file"
        log_success "Deleted: $wav_file"
        deleted_count=$((deleted_count + 1))
    fi

    # Delete MP3 if exists
    if [ -f "$mp3_file" ]; then
        rm "$mp3_file"
        log_success "Deleted: $mp3_file"
        deleted_count=$((deleted_count + 1))
    fi

    if [ $deleted_count -eq 0 ]; then
        log_warn "No audio files found to delete"
        exit 1
    fi

    log_info "Text files (transcripts, summaries) preserved"
}

list_recordings() {
    log_info "Recordings in $OUTPUT_DIR:"
    echo ""

    if [ ! -d "$OUTPUT_DIR" ] || [ -z "$(ls -A "$OUTPUT_DIR" 2>/dev/null)" ]; then
        log_warn "No recordings found"
        exit 0
    fi

    local count=0
    # Iterate through date directories (YYYYMMDD format)
    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        if [ ! -d "$date_dir" ]; then
            continue
        fi

        local date_name=$(basename "$date_dir")
        local formatted_date="${date_name:0:4}-${date_name:4:2}-${date_name:6:2}"

        # Iterate through meeting directories within each date
        for meeting_dir in "$date_dir"/meeting_*; do
            if [ ! -d "$meeting_dir" ]; then
                continue
            fi

            # Find the .wav file in the meeting directory
            local wav_file=$(find "$meeting_dir" -name "*.wav" -type f | head -1)
            if [ -z "$wav_file" ] || [ ! -f "$wav_file" ]; then
                continue
            fi

            count=$((count + 1))
            local size=$(du -h "$wav_file" | cut -f1)
            local timestamp=$(stat -c %y "$wav_file" | cut -d' ' -f1,2 | cut -d'.' -f1)
            local meeting_name=$(basename "$meeting_dir")

            # Try to load title from metadata file
            local base="${wav_file%.*}"
            local metadata_file="${base}_metadata.json"
            local title=""
            if [ -f "$metadata_file" ]; then
                title=$(grep -o '"title"[[:space:]]*:[[:space:]]*"[^"]*"' "$metadata_file" | sed 's/"title"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/')
            fi

            if [ -n "$title" ]; then
                echo "$count. $formatted_date - $title"
            else
                echo "$count. $formatted_date - $(basename "$meeting_name")"
            fi
            echo "   Path: $meeting_dir"
            echo "   Size: $size | Date: $timestamp"

            # Check for associated files
            [ -f "${base}.txt" ] && echo "   ✓ Transcription available"
            [ -f "${base}_speakers.json" ] && echo "   ✓ Diarization available"
            [ -f "${base}_summary.md" ] && echo "   ✓ Summary available"
            echo ""
        done
    done

    if [ $count -eq 0 ]; then
        log_warn "No recordings found"
    fi
}

run_post_summary_hook() {
    local summary_file="$1"

    if [ -z "$POST_SUMMARY_HOOK" ]; then
        return 0
    fi

    if [ ! -x "$POST_SUMMARY_HOOK" ]; then
        log_warn "POST_SUMMARY_HOOK is set but not executable: $POST_SUMMARY_HOOK"
        return 1
    fi

    log_info "Running post-summary hook: $POST_SUMMARY_HOOK"
    "$POST_SUMMARY_HOOK" "$summary_file"
    local exit_code=$?

    if [ $exit_code -ne 0 ]; then
        log_warn "Post-summary hook exited with code $exit_code"
        return 1
    fi

    log_success "Post-summary hook completed"
    return 0
}

catchup_recordings() {
    local dry_run=false
    local process_args=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run)
                dry_run=true
                shift
                ;;
            *)
                # Pass remaining args through to process (e.g. --no-trim, -m small)
                process_args+=("$1")
                shift
                ;;
        esac
    done

    if [ ! -d "$OUTPUT_DIR" ]; then
        log_warn "No recordings directory found: $OUTPUT_DIR"
        exit 0
    fi

    local processed=0 hooked=0 failed=0

    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        [ -d "$date_dir" ] || continue

        for meeting_dir in "$date_dir"/meeting_*; do
            [ -d "$meeting_dir" ] || continue

            local base_name
            base_name=$(basename "$meeting_dir")
            local base="${meeting_dir}/${base_name}"

            local wav_file="${base}.wav"
            local mp3_file="${base}.mp3"
            # Dual-track recordings (AUDIO_SOURCE_TYPE=dual) never create the
            # mixed ${base}.wav; they leave ${base}.voice.wav + ${base}.system.wav
            # on disk until processed. Recognise that pair so catchup does not
            # silently skip a pending dual meeting.
            local dual_voice="${base}.voice.wav"
            local has_dual=false
            [ -f "$dual_voice" ] && [ -f "${base}.system.wav" ] && has_dual=true
            local summary_file="${base}_summary.md"
            local hook_done_file="${base}.hook_done"

            # Determine title for log messages
            local title="$base_name"
            local metadata_file="${base}_metadata.json"
            if [ -f "$metadata_file" ]; then
                local meta_title
                meta_title=$(python3 -c "
import json, sys
try:
    d = json.load(open('$metadata_file'))
    print(d.get('title',''))
except Exception:
    pass
" 2>/dev/null)
                [ -n "$meta_title" ] && title="$meta_title"
            fi

            # Case 1: has audio but no summary → needs processing
            if [ ! -f "$summary_file" ] && ( [ -f "$wav_file" ] || [ -f "$mp3_file" ] || $has_dual ); then
                local audio_file=""
                [ -f "$wav_file" ] && audio_file="$wav_file"
                [ -f "$mp3_file" ] && [ -z "$audio_file" ] && audio_file="$mp3_file"
                # For a dual recording, hand `process` the voice track path; its
                # detect_dual_tracks resolves the pair and routes to dual processing.
                $has_dual && [ -z "$audio_file" ] && audio_file="$dual_voice"

                log_info "[$title] Needs processing: $(basename "$audio_file")"
                processed=$((processed + 1))

                if [ "$dry_run" = true ]; then
                    continue
                fi

                "$0" process "$audio_file" "${process_args[@]}"
                local exit_code=$?
                if [ $exit_code -ne 0 ]; then
                    log_warn "[$title] Processing failed (exit $exit_code)"
                    failed=$((failed + 1))
                    continue
                fi

                if [ ! -f "$summary_file" ]; then
                    log_warn "[$title] Processing finished but no summary found"
                    failed=$((failed + 1))
                    continue
                fi
            fi

            # Case 2: has summary but hook hasn't run → run hook
            if [ -f "$summary_file" ] && [ ! -f "$hook_done_file" ] && [ -n "$POST_SUMMARY_HOOK" ]; then
                log_info "[$title] Running post-summary hook..."

                if [ "$dry_run" = true ]; then
                    hooked=$((hooked + 1))
                    continue
                fi

                if run_post_summary_hook "$summary_file"; then
                    # Write marker so we don't re-run on next catchup
                    touch "$hook_done_file"
                    hooked=$((hooked + 1))
                else
                    log_warn "[$title] Hook failed"
                    failed=$((failed + 1))
                fi
            fi
        done
    done

    echo ""
    if [ "$dry_run" = true ]; then
        log_info "Dry run — would process: $processed, run hook: $hooked"
    else
        log_success "Catchup complete — processed: $processed, hook ran: $hooked, failed: $failed"
    fi
}

status_recordings() {
    if [ ! -d "$OUTPUT_DIR" ] || [ -z "$(ls -A "$OUTPUT_DIR" 2>/dev/null)" ]; then
        log_warn "No recordings found in $OUTPUT_DIR"
        exit 0
    fi

    local col_date=12
    local col_title=32
    local col_status=28
    local col_dur=6

    # Header
    printf "%-${col_date}s  %-${col_title}s  %-${col_status}s  %s\n" \
        "DATE" "TITLE" "STATUS" "DUR"
    printf "%-${col_date}s  %-${col_title}s  %-${col_status}s  %s\n" \
        "------------" "--------------------------------" "----------------------------" "------"

    local total=0 pending=0 partial=0 done_local=0 done_uploaded=0

    for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
        [ -d "$date_dir" ] || continue

        local date_name
        date_name=$(basename "$date_dir")
        local formatted_date="${date_name:0:4}-${date_name:4:2}-${date_name:6:2}"

        for meeting_dir in "$date_dir"/meeting_*; do
            [ -d "$meeting_dir" ] || continue

            local base_name
            base_name=$(basename "$meeting_dir")
            local base="${meeting_dir}/${base_name}"

            # Locate audio (wav preferred, then mp3)
            local wav_file="${base}.wav"
            local mp3_file="${base}.mp3"
            local txt_file="${base}.txt"
            local summary_file="${base}_summary.md"
            local metadata_file="${base}_metadata.json"
            local hook_done_file="${base}.hook_done"

            local has_wav=false has_mp3=false has_txt=false has_summary=false has_hook_done=false
            [ -f "$wav_file" ]       && has_wav=true
            [ -f "$mp3_file" ]       && has_mp3=true
            [ -f "$txt_file" ]       && has_txt=true
            [ -f "$summary_file" ]   && has_summary=true
            [ -f "$hook_done_file" ] && has_hook_done=true

            # Dual-track recordings (AUDIO_SOURCE_TYPE=dual) store audio as a
            # voice/system pair, never as the mixed ${base}.wav, so a pending dual
            # meeting would otherwise be invisible in status. Recognise the pair
            # (raw WAVs while pending, MP3s once compressed after processing).
            local has_dual=false dual_audio=""
            if [ -f "${base}.voice.wav" ] && [ -f "${base}.system.wav" ]; then
                has_dual=true; dual_audio="${base}.voice.wav"
            elif [ -f "${base}.voice.mp3" ] && [ -f "${base}.system.mp3" ]; then
                has_dual=true; dual_audio="${base}.voice.mp3"
            fi

            # Skip dirs with no recognisable audio at all and no txt either
            if ! $has_wav && ! $has_mp3 && ! $has_txt && ! $has_dual; then
                continue
            fi

            total=$((total + 1))

            # Determine status
            local status_text status_color
            if $has_summary && $has_hook_done; then
                status_text="done + hook ran"
                status_color="$GREEN"
                done_uploaded=$((done_uploaded + 1))
            elif $has_summary; then
                if [ -n "$POST_SUMMARY_HOOK" ]; then
                    status_text="done, hook pending"
                else
                    status_text="done"
                fi
                status_color="$GREEN"
                done_local=$((done_local + 1))
            elif $has_txt; then
                status_text="transcribed, no summary"
                status_color="$YELLOW"
                partial=$((partial + 1))
            elif $has_wav || $has_mp3 || $has_dual; then
                status_text="recorded, not processed"
                status_color="$YELLOW"
                pending=$((pending + 1))
            else
                status_text="unknown"
                status_color="$NC"
            fi

            # Title from metadata
            local title=""
            if [ -f "$metadata_file" ]; then
                title=$(python3 -c "
import json, sys
try:
    d = json.load(open('$metadata_file'))
    print(d.get('title',''))
except Exception:
    pass
" 2>/dev/null)
            fi
            [ -z "$title" ] && title="$base_name"

            # Duration from wav/mp3 via ffprobe if available
            local duration=""
            local audio_for_dur=""
            $has_wav && audio_for_dur="$wav_file"
            $has_mp3 && audio_for_dur="$mp3_file"
            [ -z "$audio_for_dur" ] && $has_dual && audio_for_dur="$dual_audio"
            if [ -n "$audio_for_dur" ] && command -v ffprobe &>/dev/null; then
                local secs
                secs=$(ffprobe -v error -show_entries format=duration \
                    -of default=noprint_wrappers=1:nokey=1 "$audio_for_dur" 2>/dev/null | cut -d. -f1)
                if [ -n "$secs" ] && [ "$secs" -gt 0 ] 2>/dev/null; then
                    duration=$(printf "%dm" "$((secs / 60))")
                fi
            fi

            # Truncate title for display
            local display_title="${title:0:$col_title}"

            printf "%-${col_date}s  %-${col_title}s  ${status_color}%-${col_status}s${NC}  %s\n" \
                "$formatted_date" "$display_title" "$status_text" "${duration:--}"
        done
    done

    echo ""
    echo "Total: $total  |  Pending: $pending  |  Partial: $partial  |  Done (local): $done_local  |  Done (uploaded): $done_uploaded"
}

# Main command dispatcher
main() {
    if [ $# -eq 0 ]; then
        print_usage
        exit 0
    fi

    check_dependencies

    local command="$1"
    shift

    case "$command" in
        record)
            record_meeting "$@"
            ;;
        transcribe)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 transcribe FILE [OPTIONS]"
                exit 1
            fi
            transcribe_meeting "$@"
            ;;
        summarize)
            if [ $# -eq 0 ]; then
                log_error "Missing transcription file argument"
                echo "Usage: $0 summarize FILE [OPTIONS]"
                exit 1
            fi
            summarize_meeting "$@"
            ;;
        diarize)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 diarize FILE [OPTIONS]"
                exit 1
            fi
            diarize_meeting "$@"
            ;;
        label)
            if [ $# -eq 0 ]; then
                log_error "Missing diarized file argument"
                echo "Usage: $0 label FILE"
                exit 1
            fi
            label_speakers "$@"
            ;;
        apply-labels)
            if [ $# -eq 0 ]; then
                log_error "Missing labeled file argument"
                echo "Usage: $0 apply-labels FILE [OPTIONS]"
                exit 1
            fi
            apply_speaker_labels "$@"
            ;;
        trim)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 trim FILE [--noise -30] [--min-silence 60]"
                echo ""
                echo "Detect and remove silent tail from an audio file"
                exit 1
            fi
            trim_audio "$@"
            ;;
        compress)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 compress FILE"
                echo ""
                echo "Compress WAV to MP3 and delete WAV (default workflow behavior)"
                exit 1
            fi
            compress_audio "$1" --delete-wav
            ;;
        clean)
            if [ $# -eq 0 ]; then
                log_error "Missing audio file argument"
                echo "Usage: $0 clean FILE"
                echo ""
                echo "Delete ALL audio files (WAV and MP3), keep only text/transcripts"
                exit 1
            fi
            clean_audio "$@"
            ;;
        process)
            if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
                echo "Usage: $0 process FILE [OPTIONS]"
                echo ""
                echo "Process an existing recording (transcribe + optional diarize + summarize)"
                echo ""
                echo "Options:"
                echo "  -m, --model MODEL     Whisper model (tiny|base|small|medium|large-v3, default: large-v3)"
                echo "  -l, --language LANG   Language code (uk|ru|en|auto, default: auto-detect)"
                echo "  --initial-prompt TEXT Decoding-bias sentence for tech-term spelling (overrides --hotwords)"
                echo "  --hotwords TERMS      Space-separated tech terms to bias transcription spelling"
                echo "  -o, --ollama MODEL    Ollama model for summarization"
                echo "  -s, --speakers NUM    Number of speakers (requires --diarize)"
                echo "  --diarize             Enable speaker diarization"
                echo "  --timeout SECS        Kill processing after SECS seconds (default: ${PROCESS_TIMEOUT})"
                echo ""
                echo "Examples:"
                echo "  # Simple processing (transcribe + summarize)"
                echo "  $0 process recordings/meeting.wav -m tiny"
                echo ""
                echo "  # With speaker diarization"
                echo "  $0 process recordings/meeting.wav --diarize --speakers 2 -m small"
                exit 0
            fi

            local audio_file="$1"
            shift

            if [ ! -f "$audio_file" ]; then
                log_error "Audio file not found: $audio_file"
                exit 1
            fi

            # Parse arguments
            local whisper_model="$WHISPER_MODEL"
            local whisper_language="$WHISPER_LANGUAGE"
            local whisper_initial_prompt="$WHISPER_INITIAL_PROMPT"
            local whisper_hotwords="$WHISPER_HOTWORDS"
            local ollama_model="$OLLAMA_MODEL"
            local enable_diarization=false
            local num_speakers=""
            local enable_compression=true
            local keep_wav=false
            local clean_all=false
            local process_timeout="$PROCESS_TIMEOUT"
            local enable_trim=true
            local keep_untrimmed=false
            local keep_trimmed=true

            while [[ $# -gt 0 ]]; do
                case $1 in
                    -m|--model)
                        whisper_model="$2"
                        shift 2
                        ;;
                    -l|--language)
                        whisper_language="$2"
                        shift 2
                        ;;
                    --initial-prompt)
                        whisper_initial_prompt="$2"
                        shift 2
                        ;;
                    --hotwords)
                        whisper_hotwords="$2"
                        shift 2
                        ;;
                    -o|--ollama)
                        ollama_model="$2"
                        shift 2
                        ;;
                    --diarize)
                        enable_diarization=true
                        shift
                        ;;
                    -s|--speakers)
                        num_speakers="$2"
                        shift 2
                        ;;
                    --no-compress)
                        enable_compression=false
                        shift
                        ;;
                    --keep-wav)
                        keep_wav=true
                        shift
                        ;;
                    --no-trim)
                        enable_trim=false
                        shift
                        ;;
                    --keep-untrimmed)
                        keep_untrimmed=true
                        shift
                        ;;
                    --keep-trimmed)
                        keep_trimmed=true
                        shift
                        ;;
                    --clean)
                        clean_all=true
                        shift
                        ;;
                    --timeout)
                        process_timeout="$2"
                        shift 2
                        ;;
                    *)
                        shift
                        ;;
                esac
            done

            local timeout_human
            if [ "$process_timeout" -ge 3600 ] 2>/dev/null; then
                timeout_human="$((process_timeout / 3600))h$(( (process_timeout % 3600) / 60 ))m"
            else
                timeout_human="${process_timeout}s"
            fi
            log_info "Timeout: ${timeout_human} (override with --timeout SECS or PROCESS_TIMEOUT env var)"

            # Run the entire processing block under a timeout.
            # The subshell runs as a background job; a watchdog kills the process group
            # with SIGTERM after process_timeout seconds, then SIGKILL after 30 more.
            (
            # Dual-track recording? Process the You/Remote pair without
            # diarization. Runs inside the subshell so the timeout still applies.
            local dual_base
            dual_base=$(detect_dual_tracks "$audio_file")
            if [ -n "$dual_base" ]; then
                local dual_args=(-m "$whisper_model")
                [ -n "$whisper_language" ] && dual_args+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && dual_args+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && dual_args+=(--hotwords "$whisper_hotwords")
                [ -n "$ollama_model" ] && dual_args+=(-o "$ollama_model")
                [ "$enable_compression" = false ] && dual_args+=(--no-compress)
                [ "$keep_wav" = true ] && dual_args+=(--keep-wav)
                [ "$clean_all" = true ] && dual_args+=(--clean)
                process_dual_meeting "$dual_base" "${dual_args[@]}"
            elif [ "$enable_diarization" = true ]; then
                log_info "Processing recording with diarization: $audio_file"
                echo ""

                # Step 1: Diarize
                log_info "Step 1: Identifying speakers..."
                local speakers_file
                if [ -n "$num_speakers" ]; then
                    speakers_file=$(diarize_meeting "$audio_file" -s "$num_speakers")
                else
                    speakers_file=$(diarize_meeting "$audio_file")
                fi

                if [ -z "$speakers_file" ] || [ ! -f "$speakers_file" ]; then
                    log_error "Diarization failed"
                    exit 1
                fi
                echo ""

                # Step 2: Transcribe
                log_info "Step 2: Transcribing audio..."
                local base="${audio_file%.*}"
                local transcription_json="${base}.json"

                local transcribe_cmd=("$PYTHON" "${SCRIPT_DIR}/transcribe.py" "$audio_file" -m "$whisper_model" -f json -o "$transcription_json")
                [ -n "$whisper_language" ] && transcribe_cmd+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && transcribe_cmd+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && transcribe_cmd+=(--hotwords "$whisper_hotwords")
                "${transcribe_cmd[@]}"

                if [ ! -f "$transcription_json" ]; then
                    log_error "Transcription failed"
                    exit 1
                fi
                echo ""

                # Step 3: Merge
                log_info "Step 3: Merging speaker info with transcription..."
                local diarized_file="${base}_diarized.json"

                "$PYTHON" "${SCRIPT_DIR}/merge_diarization.py" "$speakers_file" "$transcription_json" -o "$diarized_file"

                if [ ! -f "$diarized_file" ]; then
                    log_error "Merge failed"
                    exit 1
                fi
                echo ""

                # Step 4: Label speakers
                log_info "Step 4: Label speakers with their names..."
                echo ""

                # Call label_speakers without command substitution to allow interactive input
                label_speakers "$diarized_file"

                # Determine output file manually
                local base="${diarized_file%_diarized.json}"
                local labeled_file="${base}_speakers_labeled.json"

                if [ ! -f "$labeled_file" ]; then
                    log_error "Labeling failed"
                    exit 1
                fi
                echo ""

                # Step 5: Apply labels
                log_info "Step 5: Creating final transcript with speaker names..."
                local transcription_file=$(apply_speaker_labels "$labeled_file" -f txt)

                if [ -z "$transcription_file" ] || [ ! -f "$transcription_file" ]; then
                    log_error "Apply labels failed"
                    exit 1
                fi
                echo ""

                # Step 6: Summarize
                log_info "Step 6: Generating summary..."
                local summary_file
                local summarize_args=()
                [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
                [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
                summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

                if [ -z "$summary_file" ] || [ ! -f "$summary_file" ]; then
                    log_error "Summarization failed"
                    exit 1
                fi

                echo ""

                # Step 7: Compress audio and cleanup
                if [ "$clean_all" = true ]; then
                    log_info "Step 7: Removing all audio files..."
                    [ -f "$audio_file" ] && rm "$audio_file" && log_success "Deleted: $audio_file"
                    local mp3_file="${audio_file%.wav}.mp3"
                    [ -f "$mp3_file" ] && rm "$mp3_file" && log_success "Deleted: $mp3_file"
                    audio_file="(deleted)"
                    echo ""
                elif [ "$enable_compression" = true ]; then
                    log_info "Step 7: Compressing audio to MP3..."
                    local mp3_file
                    if [ "$keep_wav" = true ]; then
                        mp3_file=$(compress_audio "$audio_file")
                    else
                        mp3_file=$(compress_audio "$audio_file" --delete-wav)
                    fi

                    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                        audio_file="$mp3_file"
                    fi
                    echo ""
                fi

                log_success "Processing complete with diarization!"
                echo ""
                echo "Files generated:"
                echo "  Audio:          $audio_file"
                echo "  Diarization:    $speakers_file"
                echo "  Labeled:        $labeled_file"
                echo "  Transcription:  $transcription_file"
                echo "  Summary:        $summary_file"
            else
                # Simple transcribe + summarize workflow
                log_info "Processing recording: $audio_file"
                echo ""

                local mp3_file=""
                local transcribe_source="$audio_file"

                # Step 1: Compress WAV → MP3, delete WAV
                if [ "$clean_all" = true ]; then
                    : # skip compression, delete everything at end
                elif [ "$enable_compression" = true ]; then
                    log_info "Compressing audio to MP3..."
                    if [ "$keep_wav" = true ]; then
                        mp3_file=$(compress_audio "$audio_file")
                    else
                        mp3_file=$(compress_audio "$audio_file" --delete-wav)
                    fi
                    if [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                        transcribe_source="$mp3_file"
                    fi
                    echo ""
                fi

                # Step 2: Trim silent tail
                local trimmed_file=""
                if [ "$enable_trim" = true ] && [ -f "$transcribe_source" ]; then
                    log_info "Trimming silent tail..."
                    trimmed_file=$(trim_audio "$transcribe_source")
                    if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ]; then
                        transcribe_source="$trimmed_file"
                    fi
                    echo ""
                fi

                # Step 3: Transcribe
                local process_transcribe_args=(-m "$whisper_model")
                [ -n "$whisper_language" ] && process_transcribe_args+=(-l "$whisper_language")
                [ -n "$whisper_initial_prompt" ] && process_transcribe_args+=(--initial-prompt "$whisper_initial_prompt")
                [ -n "$whisper_hotwords" ] && process_transcribe_args+=(--hotwords "$whisper_hotwords")
                local transcription_file
                transcription_file=$(transcribe_meeting "$transcribe_source" "${process_transcribe_args[@]}")

                if [ -f "$transcription_file" ]; then
                    # Step 4: Summarize
                    local summary_file
                    local summarize_args=()
                    [ -n "$ollama_model" ] && summarize_args+=(-o "$ollama_model")
                    [ -n "$whisper_language" ] && summarize_args+=(-l "$whisper_language")
                    summary_file=$(summarize_meeting "$transcription_file" "${summarize_args[@]}")

                    echo ""

                    # Cleanup audio
                    if [ "$clean_all" = true ]; then
                        log_info "Removing all audio files..."
                        [ -f "$audio_file" ]    && rm "$audio_file"    && log_success "Deleted: $audio_file"
                        [ -n "$mp3_file" ] && [ -f "$mp3_file" ]       && rm "$mp3_file" && log_success "Deleted: $mp3_file"
                        [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && rm "$trimmed_file" && log_success "Deleted: $trimmed_file"
                        audio_file="(deleted)"
                    else
                        if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ -n "$mp3_file" ] && [ -f "$mp3_file" ]; then
                            if [ "$keep_untrimmed" = false ]; then
                                rm "$mp3_file" && log_info "Deleted untrimmed: $mp3_file"
                            fi
                        fi
                        if [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && [ "$keep_trimmed" = false ]; then
                            rm "$trimmed_file" && log_info "Deleted trimmed audio: $trimmed_file"
                        fi
                    fi

                    echo ""
                    log_success "Processing complete!"
                    echo ""
                    echo "Files generated:"
                    [ -n "$trimmed_file" ] && [ -f "$trimmed_file" ] && echo "  Audio (trimmed):  $trimmed_file"
                    [ -n "$mp3_file" ]     && [ -f "$mp3_file" ]     && echo "  Audio (full):     $mp3_file"
                    echo "  Transcription:    $transcription_file"
                    echo "  Summary:          $summary_file"

                    run_post_summary_hook "$summary_file" && \
                        touch "${summary_file%_summary.md}.hook_done" || true
                fi
            fi
            ) &
            local _proc_pid=$!

            # Watchdog: sleep in background, then kill the processing subshell
            (
                sleep "$process_timeout"
                if kill -0 "$_proc_pid" 2>/dev/null; then
                    echo "" >&2
                    echo -e "${RED}[ERROR]${NC} Processing timed out after ${timeout_human}. Stopping..." >&2
                    kill -TERM "$_proc_pid" 2>/dev/null
                    sleep 30
                    kill -KILL "$_proc_pid" 2>/dev/null
                fi
            ) &
            local _watchdog_pid=$!

            wait "$_proc_pid"
            local _exit=$?

            # Cancel the watchdog if processing finished in time
            kill "$_watchdog_pid" 2>/dev/null
            wait "$_watchdog_pid" 2>/dev/null

            if [ $_exit -eq 143 ] || [ $_exit -eq 137 ]; then
                # 143 = SIGTERM, 137 = SIGKILL
                log_error "Processing was stopped after ${timeout_human} timeout."
                log_error "Any files written before the timeout are still on disk."
                exit 1
            elif [ $_exit -ne 0 ]; then
                exit $_exit
            fi
            ;;
        process-last)
            # Find most recent recording in date/meeting subdirectories
            local latest_recording=""
            local latest_time=0

            # Search through all date directories and meeting subdirectories
            for date_dir in "$OUTPUT_DIR"/[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]; do
                if [ ! -d "$date_dir" ]; then
                    continue
                fi

                for meeting_dir in "$date_dir"/meeting_*; do
                    if [ ! -d "$meeting_dir" ]; then
                        continue
                    fi

                    # Find .wav file in meeting directory
                    local wav_file=$(find "$meeting_dir" -name "*.wav" -type f | head -1)
                    if [ -n "$wav_file" ] && [ -f "$wav_file" ]; then
                        local file_time=$(stat -c %Y "$wav_file" 2>/dev/null || echo 0)
                        if [ "$file_time" -gt "$latest_time" ]; then
                            latest_time=$file_time
                            latest_recording="$wav_file"
                        fi
                    fi
                done
            done

            if [ -z "$latest_recording" ]; then
                log_error "No recordings found in $OUTPUT_DIR"
                exit 1
            fi

            log_info "Processing most recent recording: $(basename "$(dirname "$latest_recording")")/$(basename "$latest_recording")"

            # Call process command with the latest recording
            "$0" process "$latest_recording" "$@"
            ;;
        full)
            full_workflow "$@"
            ;;
        list)
            list_recordings
            ;;
        status)
            status_recordings
            ;;
        catchup)
            catchup_recordings "$@"
            ;;
        -h|--help)
            print_usage
            ;;
        *)
            log_error "Unknown command: $command"
            echo ""
            print_usage
            exit 1
            ;;
    esac
}

main "$@"
